    { "type": "range", "id": "padding_top_mobile", "label": "Mobile Top", "min": 0, "max": 80, "step": 4, "default": 20 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile Bottom", "min": 0, "max": 80, "step": 4, "default": 20 },
    { "type": "select", "id": "layout", "label": "Desktop Layout", "default": "image-left", "options": [{ "value": "image-left", "label": "Img Left" }, { "value": "image-right", "label": "Img Right" }] },
    
    { 
      "type": "select", 
      "id": "mobile_layout", 
