        { "value": "content-top", "label": "Content First" },
        { "value": "hide-media", "label": "Hide Image/Video" }
      ] 
    },

    { "type": "select", "id": "content_align", "label": "Align", "default": "left", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }, { "value": "right", "label": "Right" }] },
    { "type": "color", "id": "bg_color", "label": "BG Color", "default": "transparent" },
    { "type": "image_picker", "id": "bg_image", "label": "BG Image" },
    { "type": "select", "id": "bg_size", "label": "BG Size", "default": "cover", "options": [{ "value": "cover", "label": "Cover" }, { "value": "contain", "label": "Contain" }] },
    { "type": "select", "id": "bg_position", "label": "Position", "default": "center center", "options": [{ "value": "center center", "label": "Center" }, { "value": "top center", "label": "Top" }] },
    { "type": "color", "id": "bg_overlay", "label": "Overlay", "default": "#000000" },
    { "type": "range", "id": "bg_overlay_opacity", "label": "Opacity", "min": 0, "max": 100, "step": 5, "default": 0, "unit": "%" }
  ],
  "blocks": [
    { 
      "type": "media", "name": "Img", "limit": 1, 
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Img" }, 
        { "type": "range", "id": "border_radius", "label": "Radius", "min": 0, "max": 60, "default": 24, "unit": "px" }, 
        { "type": "select", "id": "height_mode", "label": "Height", "default": "auto", "options": [{ "value": "auto", "label": "Auto" }, { "value": "fixed", "label": "Fixed" }] }, 
        { "type": "range", "id": "fixed_height", "label": "Height px", "min": 200, "max": 800, "step": 10, "default": 400, "unit": "px" }
      ] 
    },
    { 
      "type": "video_block", "name": "YouTube Video", "limit": 1, 
      "settings": [
        { "type": "video_url", "id": "video_url", "label": "YouTube/Vimeo Link", "accept": ["youtube", "vimeo"], "info": "Paste standard YouTube link here" }, 
        { "type": "image_picker", "id": "cover_image", "label": "Cover Image", "info": "Shows a play button before clicking. Highly recommended." },
        { "type": "range", "id": "border_radius", "label": "Radius", "min": 0, "max": 60, "default": 24, "unit": "px" }, 
        { "type": "select", "id": "height_mode", "label": "Height", "default": "auto", "options": [{ "value": "auto", "label": "Auto" }, { "value": "fixed", "label": "Fixed" }] }, 
        { "type": "range", "id": "fixed_height", "label": "Height px", "min": 200, "max": 800, "step": 10, "default": 400, "unit": "px" }
      ] 
    },
    { "type": "subhead", "name": "Sub", "settings": [{ "type": "text", "id": "text", "label": "Txt" }] },
    { "type": "title", "name": "Title", "settings": [{ "type": "text", "id": "bold", "label": "Bold" }, { "type": "text", "id": "rest", "label": "Rest" },
      {
  "type": "checkbox",
  "id": "make_h2",
  "label": "Make this an H2 heading",
  "default": false
}
    ] },

    { "type": "richtext", "name": "Txt", "settings": [{ "type": "richtext", "id": "content", "label": "Txt" }] },
    { "type": "contact_icons", "name": "Icons", "settings": [{ "type": "image_picker", "id": "icon_1", "label": "Ico 1" }, { "type": "url", "id": "link_1", "label": "Lnk 1" }, { "type": "image_picker", "id": "icon_2", "label": "Ico 2" }, { "type": "url", "id": "link_2", "label": "Lnk 2" }, { "type": "image_picker", "id": "icon_3", "label": "Ico 3" }, { "type": "url", "id": "link_3", "label": "Lnk 3" }] },
    { "type": "button", "name": "Btn", "settings": [{ "type": "text", "id": "label", "label": "Lbl" }, { "type": "url", "id": "link", "label": "Lnk" }, { "type": "select", "id": "button_style", "label": "Sty", "default": "animated", "options": [{ "value": "animated", "label": "Pri" }, { "value": "simple", "label": "Sec" }] }] }
  ],
