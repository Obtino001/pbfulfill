

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="rbc-section section-{{ section.id }}-padding" id="rbc-{{ section.id }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="rbc-container">
    <h2 class="rbc-main-title">{{ section.settings.title }}</h2>

    <div class="swiper rbc-swiper">
      <div class="swiper-wrapper rbc-grid">
        {% for block in section.blocks %}
          <div class="swiper-slide rbc-card">
            <div class="rbc-image-wrapper">
              <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.heading }}" loading="lazy">
              
              <div class="rbc-content-overlay">
                <div class="rbc-avatars">
                   {% if block.settings.avatar_1 %}<img src="{{ block.settings.avatar_1 | image_url: width: 50 }}" class="rbc-avatar">{% endif %}
                   {% if block.settings.avatar_2 %}<img src="{{ block.settings.avatar_2 | image_url: width: 50 }}" class="rbc-avatar">{% endif %}
                   {% if block.settings.avatar_3 %}<img src="{{ block.settings.avatar_3 | image_url: width: 50 }}" class="rbc-avatar">{% endif %}
                </div>
                <h3 class="rbc-card-heading">{{ block.settings.heading }}</h3>
                <p class="rbc-card-text">{{ block.settings.description }}</p>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="rbc-controls">
        <div class="swiper-button-prev rbc-nav-btn"></div>
        <div class="swiper-pagination rbc-pagination"></div>
        <div class="swiper-button-next rbc-nav-btn"></div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    new Swiper('#rbc-{{ section.id }} .rbc-swiper', {
      slidesPerView: 1.2,
      spaceBetween: 20,
      centeredSlides: true,
      loop: true,
      pagination: { el: '.rbc-pagination', clickable: true },
      navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
      breakpoints: {
        768: {
          enabled: false, /* Disable swiper on desktop */
          slidesPerView: 'auto'
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Real Brand Cases",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Real Brand Cases" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "case",
      "name": "Brand Case",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Main Image" },
        { "type": "image_picker", "id": "avatar_1", "label": "Avatar 1" },
        { "type": "image_picker", "id": "avatar_2", "label": "Avatar 2" },
        { "type": "image_picker", "id": "avatar_3", "label": "Avatar 3" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "UK beauty brand eco-bag packaging → -25% cost" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "A UK beauty brand switched to eco-friendly bag packaging..." }
      ]
    }
  ],
  "presets": [ { "name": "Real Brand Cases" } ]
}
{% endschema %}