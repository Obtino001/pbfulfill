{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .lt-container {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .lt-heading {
    text-align: center;
    font-size: 3.2rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 5rem;
    color: rgb(var(--color-foreground));
  }

  .lt-flex-wrap {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 3rem;
    max-width: 1050px;
    margin: 0 auto;
    list-style: none;
    padding: 0;
  }

  .lt-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.12);
    transition: transform 0.3s ease;
    background: rgba(var(--color-foreground), 0.05);
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .lt-card:hover {
      transform: translateY(-5px);
    }
    
    .lt-card:nth-child(1),
    .lt-card:nth-child(2) {
      width: calc(40% - 1.5rem);
      max-width: 380px;
      aspect-ratio: 3.5 / 4.5; 
    }

    .lt-card:nth-child(n+3) {
      width: calc(33.333% - 2rem);
      max-width: 300px;
      aspect-ratio: 3 / 4; 
    }
  }

  .lt-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lt-info-box {
    position: absolute;
    bottom: 2rem;
    left: 2rem;
    right: 2rem;
    background: rgb(var(--color-background));
    padding: 2rem 1.5rem;
    border-radius: 8px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    z-index: 2;
  }

  @media screen and (min-width: 750px) {
    .lt-card:nth-child(n+3) .lt-info-box {
      bottom: 1.5rem;
      left: 1.5rem;
      right: 1.5rem;
      padding: 1.5rem 1rem;
    }
  }

  .lt-name {
    display: block;
    font-size: 1.6rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0rem;
    line-height: 1.2;
  }

  .lt-desc {
    display: block;
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.7);
    line-height: 1.5;
    font-weight: 400;
    max-width: 90%;
    margin: 0 auto;
  }

  .lt-footer {
    text-align: center;
    margin-top: 6rem;
    width: 100%;
  }



  @media screen and (max-width: 749px) {
    .lt-flex-wrap {
      flex-direction: column;
      gap: 2.4rem;
    }
    
    .lt-card {
      aspect-ratio: 3 / 4;
      max-width: 400px;
      margin: 0 auto;
    }
    
    .lt-info-box {
      bottom: 1.5rem;
      left: 1.5rem;
      right: 1.5rem;
      padding: 1.5rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="lt-container">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="lt-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <ul class="lt-flex-wrap" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'team_member' -%}
          <li class="lt-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'lt-image' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'lt-image' }}
            {%- endif -%}

            <div class="lt-info-box">
              <h3 class="lt-name">{{ block.settings.name }}</h3>
              <span class="lt-desc">{{ block.settings.description }}</span>
            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- for block in section.blocks -%}
      {%- if block.type == 'button' and block.settings.btn_label != blank -%}
        <div class="lt-footer" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.btn_link }}" class="button button--primary">
            {{ block.settings.btn_label }}
          </a>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Leadership Team",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Leadership Team"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team Member",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name & Title",
          "default": "Bryan – Founder & CEO"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Supply chain strategy & business development"
        }
      ]
    },
    {
      "type": "button",
      "name": "FAQ Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "See All FAQ"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Leadership Team",
      "blocks": [
        { "type": "team_member" },
        { "type": "team_member" },
        { "type": "team_member" },
        { "type": "team_member" },
        { "type": "team_member" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}