{%- style -%}
  .cws-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .cws-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .cws-container { max-width: 1400px; margin: 0 auto; padding: 0 20px; text-align: center; }
  .cws-heading { font-size: {{ section.settings.heading_fs }}px; color: rgb(var(--color-foreground)); font-weight: 600; margin-bottom: 50px; text-align: center; font-family: inherit; }
  .cws-swiper { width: 100%; padding: 20px 10px 60px 10px !important; position: relative; overflow: hidden; }
  .cws-swiper .swiper-wrapper { align-items: stretch; }
  .cws-swiper .swiper-slide { display: flex; justify-content: center; }
  .cws-card { background: rgb(var(--color-background)); border: 1px solid rgba(var(--color-foreground), 0.08); border-radius: 16px; padding: 24px; box-shadow: 0 8px 30px rgba(0,0,0,0.06); width: 100%; text-align: center; transition: transform 0.3s ease; display: flex; flex-direction: column; align-items: center; justify-content: space-between; height: 100%; }
  .cws-card:hover { transform: translateY(-5px); }
  .cws-image-wrapper { width: 100%; aspect-ratio: 1 / 0.8; border-radius: 12px; overflow: hidden; margin-bottom: 24px; background-color: rgba(var(--color-foreground), 0.04); position: relative; }
  .cws-img { width: 100%; height: 100%; object-fit: cover; display: block; position: absolute; top: 0; left: 0; }
  .cws-title { margin: 0 0 15px 0; font-size: 1.6rem; color: rgb(var(--color-foreground)); font-family: inherit; }
  .cws-btn { display: inline-block; padding: 10px 24px; border: 1px solid rgb(var(--color-button)); color: rgb(var(--color-button)); border-radius: 50px; text-decoration: none; font-size: 1.4rem; font-weight: 500; transition: all 0.2s ease; background: transparent; width: 100%; max-width: 200px; }
  .cws-btn:hover { background-color: rgb(var(--color-button)); color: rgb(var(--color-button-text)); }
  .cws-controls { display: flex; align-items: center; justify-content: center; gap: 30px; margin-top: 10px; }
  .cws-arrow { width: 48px; height: 48px; background-color: rgb(var(--color-button)); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: opacity 0.2s; color: rgb(var(--color-button-text)); flex-shrink: 0; }
  .cws-arrow:hover { opacity: 0.85; }
  .cws-arrow.swiper-button-disabled { opacity: 0.5; cursor: not-allowed; background-color: rgba(var(--color-foreground), 0.1); color: rgb(var(--color-foreground)); border: 1px solid rgba(var(--color-foreground), 0.2); }
  .cws-arrow svg { width: 24px; height: 24px; fill: none; stroke: currentColor; stroke-width: 2; }
  .cws-pagination { position: static !important; width: auto !important; display: flex; gap: 8px; }
  .cws-pagination .swiper-pagination-bullet { width: 8px; height: 8px; background: rgba(var(--color-foreground), 0.2); opacity: 1; margin: 0 !important; }
  .cws-pagination .swiper-pagination-bullet-active { background: rgb(var(--color-button)); width: 24px; border-radius: 4px; transition: width 0.3s ease; }
  @media (max-width: 768px) { .cws-heading { font-size: {{ section.settings.heading_fs | times: 0.8 }}px; margin-bottom: 30px; } .cws-card { padding: 16px; } }
{%- endstyle -%}

<div class="cws-section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="cws-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="cws-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="swiper cws-swiper" id="swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="cws-card">
              <div class="cws-image-wrapper">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'cws-img' }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'cws-img' }}
                {%- endif -%}
              </div>
              <h3 class="cws-title">{{ block.settings.title | escape }}</h3>
              
              {%- if block.settings.button_label != blank -%}
                <a href="{{ block.settings.link | default: '#' }}" class="button button--secondary">
                  {{ block.settings.button_label | escape }}
                </a>
              {%- endif -%}
              
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="cws-controls">
      <div class="cws-arrow cws-prev-{{ section.id }}"><svg viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg></div>
      <div class="cws-pagination" id="pag-{{ section.id }}"></div>
      <div class="cws-arrow cws-next-{{ section.id }}"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></div>
    </div>
  </div>
</div>

<script>
  (function() {
    let swiperInstance = null;
    const sectionId = '{{ section.id }}';
    
    function initSwiper() {
      if (swiperInstance) swiperInstance.destroy(true, true);
      swiperInstance = new Swiper(`#swiper-${sectionId}`, {
        slidesPerView: {{ section.settings.col_mobile }},
        spaceBetween: {{ section.settings.gap_mobile }},
        centeredSlides: {{ section.settings.centered_slides }},
        loop: {{ section.settings.enable_loop }},
        {% if section.settings.enable_autoplay %}
        autoplay: { delay: {{ section.settings.autoplay_speed }}, disableOnInteraction: false },
        {% else %}
        autoplay: false,
        {% endif %}
        navigation: { nextEl: `.cws-next-${sectionId}`, prevEl: `.cws-prev-${sectionId}` },
        pagination: { el: `#pag-${sectionId}`, clickable: true },
        breakpoints: {
          768: { slidesPerView: {{ section.settings.col_tablet }}, spaceBetween: {{ section.settings.gap_desktop }}, centeredSlides: false },
          1024: { slidesPerView: {{ section.settings.col_desktop }}, spaceBetween: {{ section.settings.gap_desktop }}, centeredSlides: false }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', initSwiper);
    if (Shopify.designMode) {
      document.addEventListener('shopify:section:load', e => { if (e.detail.sectionId === sectionId) initSwiper(); });
    }
  })();
</script>

{% schema %}
{
  "name": "Categories Swiper",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },
    { "type": "header", "content": "Content Settings" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Categories we source" },
    { "type": "header", "content": "Carousel Layout (Columns)" },
    { "type": "range", "id": "col_desktop", "min": 1, "max": 6, "step": 0.1, "label": "Desktop Columns", "default": 3 },
    { "type": "range", "id": "col_tablet", "min": 1, "max": 4, "step": 0.1, "label": "Tablet Columns", "default": 2 },
    { "type": "range", "id": "col_mobile", "min": 1, "max": 3, "step": 0.1, "label": "Mobile Columns", "default": 1.2 },
    { "type": "header", "content": "Spacing & Sizing" },
    { "type": "range", "id": "gap_desktop", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Space Between (Desktop)", "default": 30 },
    { "type": "range", "id": "gap_mobile", "min": 0, "max": 50, "step": 2, "unit": "px", "label": "Space Between (Mobile)", "default": 16 },
    { "type": "header", "content": "Carousel Behavior" },
    { "type": "checkbox", "id": "enable_loop", "label": "Enable Infinite Loop", "default": true },
    { "type": "checkbox", "id": "centered_slides", "label": "Center Active Slide", "default": false },
    { "type": "checkbox", "id": "enable_autoplay", "label": "Enable Autoplay", "default": false },
    { "type": "range", "id": "autoplay_speed", "min": 1000, "max": 9000, "step": 500, "unit": "ms", "label": "Autoplay Speed", "default": 3000 },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    },
    { "type": "range", "id": "heading_fs", "min": 20, "max": 60, "step": 1, "unit": "px", "label": "Heading Font Size", "default": 36 }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Category Image" },
        { "type": "text", "id": "title", "label": "Category Name", "default": "Electronics" },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop Now" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Categories Swiper",
      "blocks": [
        { "type": "category", "settings": { "title": "Electronics", "button_label": "Shop Now" } },
        { "type": "category", "settings": { "title": "Beauty", "button_label": "Shop Now" } },
        { "type": "category", "settings": { "title": "Apparel", "button_label": "Shop Now" } },
        { "type": "category", "settings": { "title": "Home Goods", "button_label": "Shop Now" } }
      ]
    }
  ]
}
{% endschema %}