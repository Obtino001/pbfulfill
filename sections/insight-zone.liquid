<div class="insight-section-wrapper {% if section.settings.show_grid %}show-grid-bg{% endif %}">
  <div class="insight-container">
    <h2 class="insight-main-title">{{ section.settings.title }}</h2>
    
    <div class="insight-grid">
      {% for block in section.blocks %}
        <div class="insight-card">
          <div class="insight-card-header">
            <h3 class="insight-card-label">{{ block.settings.label }}</h3>
          </div>
          <div class="insight-graph-container">
            {% if block.settings.graph_image != blank %}
              <img src="{{ block.settings.graph_image | img_url: '600x' }}" alt="{{ block.settings.label }}">
            {% else %}
              <div class="placeholder-graph"></div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    
    <p class="insight-footer">{{ section.settings.footer_text }}</p>
  </div>
</div>

<style>
  .insight-section-wrapper {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 20px;
    padding-right: 20px;
    background-color: #ffffff;
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .insight-section-wrapper {
       padding-top: {{ section.settings.padding_top }}px;
       padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  /* Optional Grid Background to match your screenshot */
  .insight-section-wrapper.show-grid-bg {
    background-image: 
      linear-gradient(rgba(226, 232, 240, 0.3) 1px, transparent 1px),
      linear-gradient(90deg, rgba(226, 232, 240, 0.3) 1px, transparent 1px);
    background-size: 40px 40px;
    background-position: center;
  }
  .insight-container {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 2;
  }
  .insight-main-title {
    font-size: 30px;
    font-weight: 600;
    color: #4a5568;
    margin-bottom: 50px;
  }
  .insight-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }
  .insight-card {
    background: #ffffff;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 15px 45px rgba(0,0,0,0.06);
    border: 1px solid #f0f4f8;
    transition: transform 0.3s ease;
  }
  .insight-card:hover {
    transform: translateY(-5px);
  }
  .insight-card-header {
    padding: 15px 20px;
    text-align: left;
    border-bottom: 1px solid #f7fafc;
  }
  .insight-card-label {
    font-size: 13px;
    font-weight: 600;
    color: #2d3748;
    text-transform: capitalize;
  }
  .insight-graph-container {
    padding: 20px;
    background: #ffffff;
    min-height: 180px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .insight-graph-container img {
    width: 100%;
    height: auto;
    display: block;
  }
  .placeholder-graph {
    width: 100%;
    height: 150px;
    background: linear-gradient(90deg, transparent, #f7fafc, transparent);
    border-radius: 4px;
  }
  .insight-footer {
    margin-top: 40px;
    font-size: 13px;
    color: #718096;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .insight-grid {
      grid-template-columns: 1fr;
    }
    .insight-main-title { font-size: 24px; }
  }
</style>

{% schema %}
{
  "name": "Insight Zone",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Data-Backed Insight Zone"
    },
    {
      "type": "checkbox",
      "id": "show_grid",
      "label": "Show Grid Background Pattern",
      "default": true
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "All guides are backed by real market data not guesswork."
    }
  ],
  "blocks": [
    {
      "type": "chart",
      "name": "Chart Card",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "label", "label": "Card Label", "default": "Growth Index" },
        { "type": "image_picker", "id": "graph_image", "label": "Graph Image (Blue Line)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Insight Zone",
      "blocks": [
        { "type": "chart", "settings": { "label": "TikTok Growth Index" } },
        { "type": "chart", "settings": { "label": "Amazon Best Seller Momentum" } },
        { "type": "chart", "settings": { "label": "Google Trend +120% climb" } },
        { "type": "chart", "settings": { "label": "Factory output capacity rise" } }
      ]
    }
  ]
}
{% endschema %}