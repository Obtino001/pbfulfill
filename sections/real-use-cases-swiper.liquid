{%- style -%}
  #ins-section-{{ section.id }} { 
    position: relative; 
    background-color: {{ section.settings.bg_color }}; 
    padding-top: {{ section.settings.padding_top_mobile }}px; 
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px; 
    overflow: hidden; 
    text-align: center; 
    {% if section.settings.bg_pattern != blank %} 
      background-image: url('{{ section.settings.bg_pattern | image_url: width: 1920 }}'); 
      background-size: cover; 
      background-position: center; 
    {% endif %} 
  }
  @media screen and (min-width: 750px) { 
    #ins-section-{{ section.id }} { 
      padding-top: {{ section.settings.padding_top }}px; 
      padding-bottom: {{ section.settings.padding_bottom }}px; 
    } 
  }
  
  .ins-container-{{ section.id }} { max-width: 1400px; margin: 0 auto; padding: 0 20px; }
  .ins-heading-{{ section.id }} { font-size: 3.2rem; font-weight: 700; color: rgb(var(--color-foreground)); margin-bottom: 1.6rem; font-family: inherit; }
  .ins-subtext-{{ section.id }} { font-size: 1.6rem; color: rgba(var(--color-foreground), 0.75); max-width: 800px; margin: 0 auto 50px auto; line-height: 1.6; font-family: inherit; }
  
  .swiper-container-{{ section.id }} { 
    width: 100%; 
    padding: 20px 20px 40px 20px !important; 
    margin: -20px -20px 0 -20px !important; 
    overflow: hidden !important; 
    opacity: 0; 
    transition: opacity 0.3s ease; 
  }
  .swiper-container-{{ section.id }}.swiper-initialized { opacity: 1; }
  
  .ins-slide-{{ section.id }} { position: relative; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 20px rgba(0,0,0,0.08); background: rgb(var(--color-background)); aspect-ratio: 1 / 1; transition: transform 0.3s ease; border: 1px solid rgba(var(--color-foreground), 0.04); height: auto; }
  .ins-slide-{{ section.id }}:hover { transform: translateY(-5px); }
  .ins-img-{{ section.id }} { width: 100%; height: 100%; object-fit: cover; display: block; }
  
  .ins-badge-{{ section.id }} { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); background: rgb(var(--color-background)); padding: 8px 20px; border-radius: 50px; display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.15); white-space: nowrap; z-index: 2; border: 1px solid rgba(var(--color-foreground), 0.04); }
  .ins-badge-icon-{{ section.id }} svg { width: 10px; height: 10px; fill: none; stroke: currentColor; stroke-width: 3; }
  .ins-badge-text-{{ section.id }} { font-size: 1.4rem; font-weight: 600; color: rgb(var(--color-foreground)); margin: 5px; }
  
  /* --- Navigation & Pagination Styles --- */
  .ins-controls-{{ section.id }} { display: flex; align-items: center; justify-content: center; gap: 20px; margin-top: 10px; }
  
  .ins-arrow-{{ section.id }} { 
    width: 48px; 
    height: 48px; 
    background-color: #2961BE; /* Brand Blue */
    border-radius: 50%; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    cursor: pointer; 
    color: #ffffff; 
    transition: transform 0.2s ease, opacity 0.3s ease; 
    flex-shrink: 0;
  }
  .ins-arrow-{{ section.id }}:active { transform: scale(0.95); }
  .ins-arrow-{{ section.id }} svg { width: 24px; height: 24px; fill: none; stroke: currentColor; stroke-width: 2; }
  .ins-arrow-{{ section.id }}.swiper-button-disabled { opacity: 0.4; cursor: not-allowed; }
  
  .ins-pagination-{{ section.id }} { 
    display: flex; 
    align-items: center;
    justify-content: center;
    gap: 8px; 
    background: #ffffff;
    padding: 12px 20px;
    border-radius: 40px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
    width: auto !important; 
  }
  
  /* Custom Swiper Bullets */
  .ins-pagination-{{ section.id }} .swiper-pagination-bullet { 
    width: 8px; 
    height: 8px; 
    background: #D9D9D9; 
    opacity: 1; 
    margin: 0 !important; 
    border-radius: 10px; 
    cursor: pointer; 
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  /* Expanding Pill active state */
  .ins-pagination-{{ section.id }} .swiper-pagination-bullet-active { 
    background: #2961BE; 
    width: 20px; 
  }
{%- endstyle -%}

<div id="ins-section-{{ section.id }}" class="color-{{ section.settings.color_scheme }} gradient">
  <div class="ins-container-{{ section.id }}">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="ins-heading-{{ section.id }}">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    
    {%- if section.settings.subtext != blank -%}
      <p class="ins-subtext-{{ section.id }}">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}

    <div class="swiper swiper-container-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide ins-slide-{{ section.id }}" {{ block.shopify_attributes }}>
            
            {%- if block.settings.image != blank -%}
              {% assign img_pos = block.settings.image_position | default: 'center' %}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.label | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                class="ins-img-{{ section.id }}"
                style="object-position: {{ img_pos }};"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'ins-img-' | append: section.id }}
            {%- endif -%}

            <div class="ins-badge-{{ section.id }}">
              <div class="ins-badge-icon-{{ section.id }}">
                {% if block.settings.icon_image != blank %}
                  {{ block.settings.icon_image | image_url: width: 40 | image_tag: loading: 'lazy' }}
                {% endif %}
              </div>
              <h3 class="ins-badge-text-{{ section.id }}">{{ block.settings.label | escape }}</h3>
            </div>

          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="ins-controls-{{ section.id }}">
      <div class="ins-arrow-{{ section.id }} ins-prev-{{ section.id }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </div>

      <div class="ins-pagination-{{ section.id }}"></div>

      <div class="ins-arrow-{{ section.id }} ins-next-{{ section.id }}">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    let swiperInstance = null;
    const sectionId = '{{ section.id }}';
    
    // Fixed Selectors to match the HTML above
    const selector = `.swiper-container-${sectionId}`;
    const paginationSelector = `.ins-pagination-${sectionId}`;
    const nextSelector = `.ins-next-${sectionId}`;
    const prevSelector = `.ins-prev-${sectionId}`;

    function initSwiper() {
      const container = document.querySelector(selector);
      if (!container) return;

      if (!swiperInstance) {
        let swiperOptions = {
          slidesPerView: {{ section.settings.col_mobile }},
          spaceBetween: {{ section.settings.gap_mobile }},
          centeredSlides: {{ section.settings.centered_slides_mobile }},
          loop: {{ section.settings.loop }}, 
          loopedSlides: 3, 
          pagination: {
            el: paginationSelector,
            clickable: true,
          },
          navigation: {
            nextEl: nextSelector,
            prevEl: prevSelector,
          },
          breakpoints: {
            768: {
              slidesPerView: {{ section.settings.col_tablet }},
              spaceBetween: {{ section.settings.gap_desktop }},
              centeredSlides: false
            },
            1024: {
              slidesPerView: {{ section.settings.col_desktop }},
              spaceBetween: {{ section.settings.gap_desktop }},
              centeredSlides: false
            }
          }
        };

        {% if section.settings.autoplay %}
          swiperOptions.autoplay = {
            delay: {{ section.settings.autoplay_speed }},
            disableOnInteraction: false,
          };
        {% endif %}

        swiperInstance = new Swiper(selector, swiperOptions);
      }
    }

    if (typeof Swiper !== 'undefined') {
      initSwiper();
    } else {
      const swiperScript = document.querySelector('script[src*="swiper-bundle"]');
      if(swiperScript) {
        swiperScript.addEventListener('load', initSwiper);
      }
    }
    
    document.addEventListener('shopify:section:load', function(event) {
        if (event.detail.sectionId === sectionId) {
          if (swiperInstance) {
            swiperInstance.destroy(true, true);
            swiperInstance = null;
          }
          initSwiper();
        }
    });
  });
</script>

{% schema %}
{
  "name": "Inspection Facility",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },
    { "type": "header", "content": "Text Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Our Inspection Facility" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Our warehouse is equipped with professional tools." },
    { "type": "header", "content": "Background" },
    { "type": "color", "id": "bg_color", "label": "Background Override", "default": "transparent" },
    { "type": "image_picker", "id": "bg_pattern", "label": "Background Pattern/Image", "info": "Upload the grid pattern here if you have it" },
    { "type": "header", "content": "Slider Layout" },
    { "type": "range", "id": "col_desktop", "min": 1, "max": 4, "step": 1, "label": "Desktop Columns", "default": 3 },
    { "type": "range", "id": "col_tablet", "min": 1, "max": 4, "step": 0.1, "label": "Tablet Columns", "default": 2 },
    { "type": "range", "id": "col_mobile", "min": 1, "max": 3, "step": 0.1, "label": "Mobile Columns", "default": 1.2 },
    { "type": "range", "id": "gap_desktop", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Space Between (Desktop)", "default": 30 },
    { "type": "range", "id": "gap_mobile", "min": 0, "max": 50, "step": 2, "unit": "px", "label": "Space Between (Mobile)", "default": 20 },
    { "type": "header", "content": "Slider Behavior" },
    { "type": "checkbox", "id": "loop", "label": "Enable Loop", "default": true },
    { "type": "checkbox", "id": "centered_slides_mobile", "label": "Center Active Slide (Mobile)", "default": true },
    { "type": "checkbox", "id": "autoplay", "label": "Enable Autoplay", "default": false },
    { "type": "range", "id": "autoplay_speed", "min": 1000, "max": 8000, "step": 500, "unit": "ms", "label": "Autoplay Speed", "default": 3000 },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "facility_image",
      "name": "Facility Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image Position",
          "options": [
            { "value": "20% 0", "label": "Top Left" },
            { "value": "top", "label": "Top Center" },
            { "value": "80% 0", "label": "Top Right" },
            { "value": "20% 50%", "label": "Center Left" },
            { "value": "center", "label": "Center" },
            { "value": "80% 50%", "label": "Center Right" },
            { "value": "20% 100%", "label": "Bottom Left" },
            { "value": "bottom", "label": "Bottom Center" },
            { "value": "80% 100%", "label": "Bottom Right" }
          ],
          "default": "center"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Badge Icon"
        },
        { "type": "text", "id": "label", "label": "Badge Label", "default": "Facility Name" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Inspection Facility Slider",
      "blocks": [
        { "type": "facility_image" },
        { "type": "facility_image" },
        { "type": "facility_image" },
        { "type": "facility_image" }
      ]
    }
  ]
}
{% endschema %}