{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom CSS class"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why Choose Us?"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 36
    },
    {
      "type": "header",
      "content": "Padding Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon/Image"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Feature description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        { "type": "card", "settings": { "text": "Transparent Pricing & No Hidden Fees" } },
        { "type": "card", "settings": { "text": "1 On 1 Dedicated Agent Support" } },
        { "type": "card", "settings": { "text": "Access to Verified Factories Only" } },
        { "type": "card", "settings": { "text": "Access to Verified Factories Only" } }
      ]
    }
  ]
}
{% endschema %}

<div class="wcu-section color-{{ section.settings.color_scheme }} gradient {{ section.settings.custom_class }} section-{{ section.id }}-padding">
  <div class="wcu-container page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="h1">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="wcu-grid">
      {%- for block in section.blocks -%}
        <div class="wcu-card color-{{ section.settings.color_scheme }} gradient" {{ block.shopify_attributes }}>
          <div class="wcu-icon-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: class: 'wcu-icon', loading: 'lazy' }}
            {%- else -%}
              <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="rgba(var(--color-foreground), 0.5)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline>
              </svg>
            {%- endif -%}
          </div>
          <h3 class="wcu-text">{{ block.settings.text }}</h3>
        </div>
      {%- endfor -%}
    </div>
    
  </div>
</div>

<style>
  .wcu-section { position: relative; overflow: hidden; width: 100%; box-sizing: border-box; }
  .wcu-container { text-align: center; }
  .wcu-grid { display: flex; justify-content: center; align-items: flex-start; flex-wrap: wrap; gap: 20px; }
  .wcu-card { background: rgb(var(--color-background)); border-radius: 12px; padding: 30px 20px; width: calc(25% - 15px); min-width: 220px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; transition: transform 0.3s ease, box-shadow 0.3s ease; box-sizing: border-box; border: 1px solid rgba(var(--color-foreground), 0.08); box-shadow: 0px 10px 30px rgba(0,0,0,0.04); }
  .wcu-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.08); }
  .wcu-icon-wrapper { margin-bottom: 20px; display: flex; align-items: center; justify-content: center; }
  .wcu-icon {
      max-width: 100%;
      max-height: 240px;
      object-fit: cover;
      display: block;
      border-radius: 8px;
  }
  .wcu-text { font-size: 16px; font-weight: 600; line-height: 1.4; color: rgba(var(--color-foreground), 0.85); }
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  @media (min-width: 990px) { .wcu-card:nth-child(2), .wcu-card:nth-child(3) { margin-top: 50px; } }
  @media (max-width: 989px) { .wcu-card { width: calc(50% - 10px); } .wcu-card:nth-child(2), .wcu-card:nth-child(3) { margin-top: 0; } }
  @media (max-width: 600px) { .wcu-card { width: 100%; } }
</style>