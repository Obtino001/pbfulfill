{%- style -%}
  .os-section-{{ section.id }} { 
    --bg-color: {{ section.settings.bg_color }}; 
    background-image: {% if section.settings.bg_image != blank %}url('{{ section.settings.bg_image | image_url: width: 2000 }}'){% else %}none{% endif %};
    --btn-color: {{ section.settings.button_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px; 
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px; 
  }
  @media screen and (min-width: 750px) { 
    .os-section-{{ section.id }} { 
      padding-top: {{ section.settings.padding_top }}px; 
      padding-bottom: {{ section.settings.padding_bottom }}px; 
    } 
  }
{%- endstyle -%}

<div class="os-section os-section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="os-container">
    {% if section.settings.heading != blank %}
      <h2 class="os-heading h1">{{ section.settings.heading | escape }}</h2>
    {% endif %}
    
    <div class="os-card">
      <div class="os-card-inner">
        {% if section.settings.card_image != blank %}
          <div class="os-image-wrapper">
            {{ section.settings.card_image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'os-img' }}
          </div>
        {% else %}
          <div class="os-image-wrapper os-placeholder">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
        
        {% if section.settings.card_text != blank %}
          <div class="os-text-content">
            {{ section.settings.card_text }}
          </div>
        {% endif %}

        {%- if section.settings.button_label != blank -%}
          <div class="os-button-wrapper">
            <a href="{{ section.settings.button_link | default: '#' }}" class="button button--secondary">
              {{ section.settings.button_label | escape }}
            </a>
          </div>
        {%- endif -%}

      </div>
    </div>

    {% if section.settings.footer_text != blank %}
      <div class="pl-footer-wrapper">
      <p class="pl-footer-text">{{ section.settings.footer_text | escape }}</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Wide Image with Text",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },
    { "type": "image_picker", "id": "bg_image", "label": "Background Grid Image" },
    { "type": "color", "id": "bg_color", "label": "Background Override", "default": "transparent" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Niche of the Month" },
    { "type": "header", "content": "Card Content" },
    { "type": "image_picker", "id": "card_image", "label": "Card Image" },
    { "type": "richtext", "id": "card_text", "label": "Card Text", "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>" },
    { "type": "header", "content": "Card Button" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "Read Guide" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "color", "id": "button_color", "label": "Button Color", "default": "#E32C2B" },
    { "type": "header", "content": "Footer Content" },
    { "type": "text", "id": "footer_text", "label": "Bottom Caption", "default": "We believe every seller deserves a dependable partner." }
  ],
  "presets": [{ "name": "Wide Image with Text" }]
}
{% endschema %}