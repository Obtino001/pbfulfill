{% schema %}
{
  "name": "Dropshipping Solutions",
  "settings": [
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" },
    { "type": "text", "id": "aria_label", "label": "Aria label", "default": "Dropshipping Solutions" },
    { "type": "image_picker", "id": "bg_image", "label": "Background image (optional)" },
    { "type": "image_picker", "id": "image", "label": "Right image" },
     {
      "type": "header",
      "content": "Padding Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "subhead",
      "name": "Subhead",
      "settings": [{ "type": "text", "id": "text", "label": "Text", "default": "Subheading" }]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [{ "type": "text", "id": "title", "label": "Heading", "default": "Unlock Your Business Potential" }]
    },
    {
      "type": "paragraph",
      "name": "Paragraph",
      "settings": [
        { "type": "checkbox", "id": "is_rich", "label": "Use rich text", "default": false },
        {
          "type": "textarea",
          "id": "body",
          "label": "Text",
          "default": "Get started with our services to grow your business."
        },
        {
          "type": "select",
          "id": "variant",
          "label": "Style",
          "default": "default",
          "options": [
            { "value": "default", "label": "Default" },
            { "value": "highlight", "label": "Grey highlight bar" }
          ]
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        { "type": "text", "id": "label", "label": "Button text", "default": "Request A Free Quote" },
        { "type": "url", "id": "link", "label": "Button link URL" },
        { "type": "checkbox", "id": "new_tab", "label": "Open in new tab", "default": false },
        {
          "type": "select",
          "id": "style",
          "label": "Button style",
          "default": "primary",
          "options": [
            { "value": "primary", "label": "Primary (animated)" },
            { "value": "ghost", "label": "Ghost (white chip)" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dropshipping Solutions",
      "blocks": [
        { "type": "subhead" },
        { "type": "heading" },
        { "type": "paragraph" },
        {
          "type": "paragraph",
          "settings": { "body": "We offer tailored solutions to meet your needs.", "variant": "highlight" }
        },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
