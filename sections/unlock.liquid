<section
  class="page-width section-{{ section.id }}-padding"
  aria-label="{{ section.settings.aria_label | escape }}"
>
  <div class="unl-wrap {{ section.settings.custom_class }}">
    <div class="unl-inner">
      <div class="unl-col unl-col-text">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'subhead' %}
              {% if block.settings.text %}
                <p class="unl-subhead" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</p>
              {% endif %}
            {% when 'heading' %}
              {% if block.settings.title %}
                <h2 class="h1" {{ block.shopify_attributes }}>{{ block.settings.title | escape }}</h2>
              {% endif %}
            {% when 'paragraph' %}
              {% if block.settings.body %}
                <div class="unl-p-wrap {{ block.settings.variant }}" {{ block.shopify_attributes }}>
                  {% if block.settings.is_rich -%}
                    {{- block.settings.body -}}
                  {%- else %}
                    <p class="unl-p{% if block.settings.variant == 'highlight' %} unl-grey{% endif %}">
                      {{ block.settings.body | escape }}
                    </p>
                  {% endif %}
                </div>
              {% endif %}
            {% when 'button' %}
              {% if block.settings.label and block.settings.link %}
                <a
                  class="button button--primary{% if block.settings.style == 'ghost' %} unl-btn{% endif %}"
                  href="{{ block.settings.link }}"
                  {% if block.settings.new_tab %}
                    target="_blank" rel="noopener noreferrer"
                  {% endif %}
                  {{ block.shopify_attributes }}
                >
                  <span class="text">{{ block.settings.label }}</span>
                </a>
              {% endif %}
          {% endcase %}
        {% endfor %}
      </div>
      <div class="unl-col unl-col-media">
        {% if section.settings.image %}
          <img
            src="{{ section.settings.image | image_url: width: 1200 }}"
            alt="image"
            loading="lazy"
            decoding="async"
          >
        {% endif %}
      </div>
    </div>
  </div>
</section>
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
