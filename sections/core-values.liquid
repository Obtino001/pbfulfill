<div class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="section-heading center">
      <h2 class="inline-richtext {{ section.settings.heading_size }}">{{ section.settings.title }}</h2>
    </div>

    {%- capture card_blocks -%}
      {% for block in section.blocks %}
        <div class="cv-custom-item" {{ block.shopify_attributes }}>
          <div class="value-card center">
            {% if block.settings.image != blank %}
              <div class="value-card__image-wrapper">
                {{ block.settings.image | image_url: width: 240 | image_tag: 
                  loading: 'lazy', 
                  class: 'value-card__img' 
                }}
              </div>
            {% endif %}
            <div class="value-card__info">
              <h3 class="inline-richtext h4">{{ block.settings.title_text }}</h3>
              <p class="rte">{{ block.settings.desc_text }}</p>
            </div>
          </div>
        </div>
      {% endfor %}
    {%- endcapture -%}

    <div class="values-grid-container">
      <div class="cv-custom-grid" style="--grid-desktop-gap: {{ section.settings.spacing }}px;">
        {{ card_blocks }}
      </div>
    </div>
  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    overflow-x: hidden;
  }

  /* Value Card Styling */
  .value-card {
    height: 100%;
    padding: 3rem 2rem;
    border: 1px solid #E9EAEB;
    box-shadow: 0px 0px 48px -12px rgba(10, 13, 18, 0.18);
    transition: transform 0.3s ease;
    background: rgb(var(--color-background));
    border-radius: 12px;
  }

  .value-card:hover {
    transform: translateY(-5px);
  }

  .value-card__image-wrapper {
    margin: 0 auto 2rem;
    max-width: 120px;
  }

  .value-card__img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* --- Desktop Layout (Custom Grid) --- */
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    
    .section-{{ section.id }}-padding .cv-custom-grid {
      display: grid !important;
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr) !important;
      column-gap: var(--grid-desktop-gap);
      row-gap: var(--grid-desktop-gap);
    }
  }

  /* --- Mobile Layout (Manual Snap Scroll) --- */
  @media screen and (max-width: 749px) {
    .values-grid-container {
      margin: 0 -1.5rem; /* Allow cards to bleed to screen edges */
      overflow: hidden; /* Hide anything outside the screen bounds */
    }

    .cv-custom-grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      scrollbar-width: none;
      padding-block: 2rem;
      padding-inline: 1.5rem;
      gap: 15px;
    }
    
    .cv-custom-grid::-webkit-scrollbar {
      display: none;
    }
    
    .cv-custom-grid .cv-custom-item {
      flex: 0 0 80%;
      scroll-snap-align: center;
      max-width: none;
    }
  }
</style>

{% schema %}
{
  "name": "Core Values",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Heading",
      "default": "Our Core Values"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4,
      "label": "Number of columns on desktop"
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Grid gap (Desktop)",
      "default": 20
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Icon Image" },
        { "type": "inline_richtext", "id": "title_text", "label": "Title", "default": "Value Title" },
        { "type": "text", "id": "desc_text", "label": "Description", "default": "Value description goes here" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Core Values",
      "blocks": [
        { "type": "value" },
        { "type": "value" },
        { "type": "value" },
        { "type": "value" }
      ]
    }
  ]
}
{% endschema %}