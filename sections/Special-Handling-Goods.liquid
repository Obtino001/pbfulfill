{% schema %}
{
  "name": "Special Handling Goods",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Special Handling Sensitive Goods Support"
    },
    {
      "type": "inline_richtext",
      "id": "footer_text",
      "label": "Footer Note",
      "default": "Free protective packaging included."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Handling Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "Bubble wrap"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Special Handling Goods",
      "blocks": [
        { "type": "card", "settings": { "label": "Bubble wrap" } },
        { "type": "card", "settings": { "label": "Waterproof bags" } }
      ]
    }
  ]
}
{% endschema %}

<div class="color-{{ section.settings.color_scheme }} gradient x-shsg-wrapper section-{{ section.id }}-padding">
  <div class="x-shsg-container page-width">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="x-shsg-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="x-shsg-grid">
      {%- for block in section.blocks -%}
        <div class="x-shsg-card" {{ block.shopify_attributes }}>
          <div class="x-shsg-image-box">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'x-shsg-img' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'x-shsg-placeholder' }}
            {%- endif -%}
          </div>
          {%- if block.settings.label != blank -%}
            <div class="x-shsg-label-box">
            <h3>
  {%- if block.settings.link != blank -%}
    <a href="{{ block.settings.link }}" class="button button--secondary">{{ block.settings.label }}</a>
  {%- else -%}
    <span class="button button--secondary">{{ block.settings.label }}</span>
  {%- endif -%}
</h3>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank -%}
      <div class="pl-footer-wrapper">
      <p class="pl-footer-text">{{ section.settings.footer_text }}</p>
      </div>
    {%- endif -%}

  </div>
</div>

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .x-shsg-wrapper { overflow: hidden; }
  .x-shsg-container { max-width: 1000px; margin: 0 auto; }
  .x-shsg-heading { text-align: center; font-size: 32px; font-weight: 700; color: rgb(var(--color-foreground)); margin-bottom: 50px; letter-spacing: -0.5px; }
  .x-shsg-grid { display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; }
  .x-shsg-card { background: rgb(var(--color-background)); border-radius: 16px; padding: 16px 16px 30px 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.08); flex: 1; min-width: 320px; max-width: 440px; display: flex; flex-direction: column; align-items: center; border: 1px solid rgba(var(--color-foreground), 0.05); transition: transform 0.3s ease; }
  .x-shsg-card:hover { transform: translateY(-5px); }
  .x-shsg-image-box { width: 100%; border-radius: 12px; overflow: hidden; margin-bottom: 24px; aspect-ratio: 16 / 10; background: rgba(var(--color-foreground), 0.03); display: flex; align-items: center; justify-content: center; }
  .x-shsg-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .x-shsg-placeholder { width: 100%; height: 100%; fill: rgba(var(--color-foreground), 0.1); }
  .x-shsg-label-box { display: flex; justify-content: center; width: 100%; }
  /* Notice the pill CSS is gone, Dawn handles the button styling now */

  @media (max-width: 768px) { .x-shsg-grid { flex-direction: column; align-items: center; gap: 24px; } .x-shsg-card { width: 100%; max-width: 100%; padding: 12px 12px 24px 12px; } .x-shsg-heading { font-size: 26px; margin-bottom: 40px; } .x-shsg-image-box { margin-bottom: 20px; } }
</style>