{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {% if section.settings.mobile_bg != blank %}
  @media screen and (max-width: 749px) {
    .mobile-bg-{{ section.id }} {
      background: url('{{ section.settings.mobile_bg | image_url: width: 750 }}') center / cover no-repeat !important;
    }
  }
  {% endif %}

  .ns-container {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ns-heading {
    text-align: center;
    font-size: 3.2rem;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 5rem;
    color: rgb(var(--color-foreground));
  }

  .ns-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ns-card {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 1 / 1.1;
    box-shadow: 0 10px 30px rgba(var(--color-foreground), 0.08);
    transition: transform 0.3s ease;
  }

  @media screen and (min-width: 750px) {
    .ns-card:hover {
      transform: translateY(-5px);
    }
    .ns-card:hover .ns-bg-img {
      transform: scale(1.05);
    }
  }

  .ns-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .ns-placeholder {
    width: 100%;
    height: 100%;
    background: rgba(var(--color-foreground), 0.05);
    display: block;
  }

  .ns-content {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    right: 1.5rem;
    background: rgb(var(--color-background));
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 4px 15px rgba(var(--color-foreground), 0.05);
    z-index: 2;
  }

  .ns-card-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0 0 0.8rem 0;
    line-height: 1.4;
  }

  .ns-card-text {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
    line-height: 1.5;
  }

  .ns-btn-wrapper {
    margin-top: 4rem;
    text-align: center;
    width: 100%;
  }

  @media screen and (max-width: 900px) and (min-width: 750px) {
    .ns-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ns-grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      gap: 1.6rem;
      margin: 0 -1.5rem;
      padding: 0 1.5rem 2rem 1.5rem;
    }
    
    .ns-grid::-webkit-scrollbar {
      display: none;
    }

    .ns-card {
      flex: 0 0 85%;
      scroll-snap-align: center;
      aspect-ratio: auto;
      height: 380px;
    }

    .ns-heading {
      font-size: 2.6rem;
      margin-bottom: 3rem;
    }
    
    .ns-btn-wrapper {
      margin-top: 2rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding mobile-bg-{{ section.id }}">
  <div class="ns-container">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="ns-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <ul class="ns-grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          <li class="ns-card" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'ns-bg-img' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg ns-placeholder' }}
            {%- endif -%}

            <div class="ns-content">
              <h3 class="ns-card-title">{{ block.settings.title }}</h3>
              <p class="ns-card-text">{{ block.settings.text }}</p>
            </div>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- for block in section.blocks -%}
      {%- if block.type == 'button' and block.settings.btn_label != blank -%}
        <div class="ns-btn-wrapper" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.btn_link }}" class="button button--secondary">
            {{ block.settings.btn_label }}
          </a>
        </div>
      {%- endif -%}
    {%- endfor -%}

  </div>
</div>

{% schema %}
{
  "name": "Niche Strategy Cards",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Niche Strategy Transformed Stores"
    },
    {
      "type": "image_picker",
      "id": "mobile_bg",
      "label": "Mobile Background Image",
      "info": "Displays only on mobile devices (< 750px)."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Strategy Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Pet niche store → GMV +300%"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Send the returned items to the nearest designated warehouse for faster processing."
        }
      ]
    },
    {
      "type": "button",
      "name": "FAQ Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "See All Faq"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Niche Strategy Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Travel gear → Viral on TikTok"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Activewear → Private Label uplift"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Pet niche store → GMV +300%"
          }
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}