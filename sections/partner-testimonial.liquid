{% schema %}
{
  "name": "Partner Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Partner Testimonial"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Marquee Settings"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Marquee Speed",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Review Card",
      "limit": 3,
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "default": 5
        },
        {
          "type": "text",
          "id": "quote",
          "label": "Review Text",
          "default": "The sample testing process saved us from costly returns."
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author Photo"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "James T."
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author Title",
          "default": "UK Ecommerce Store Owner"
        },
        {
          "type": "image_picker",
          "id": "company_logo",
          "label": "Company Logo"
        }
      ]
    },
    {
      "type": "logo",
      "name": "Marquee Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logistics Logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Partner Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="pt-container page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="pt-heading h1 center">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="pt-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial' -%}
          <div class="pt-card" {{ block.shopify_attributes }}>
            <div class="pt-stars">
              {%- for i in (1..block.settings.stars) -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#F5C518"><path d="M12 17.27L18.18 21L16.54 13.97L22 9.24L14.81 8.63L12 2L9.19 8.63L2 9.24L7.46 13.97L5.82 21L12 17.27Z"/></svg>
              {%- endfor -%}
            </div>
            <p class="pt-quote">{{ block.settings.quote }}</p>
            <div class="pt-card-footer">
              <div class="pt-author-info">
                <div class="pt-avatar">
                  {%- if block.settings.author_image -%}
                    {{ block.settings.author_image | image_url: width: 80 | image_tag: loading: 'lazy' }}
                  {%- else -%}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
                <div class="pt-meta">
                  <h3 class="pt-name">{{ block.settings.author_name }}</h3>
                  <span class="pt-title">{{ block.settings.author_title }}</span>
                </div>
              </div>
              {%- if block.settings.company_logo -%}
                <div class="pt-company-logo">{{ block.settings.company_logo | image_url: width: 120 | image_tag: loading: 'lazy' }}</div>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="pt-marquee-wrapper">
    <div class="pt-marquee-track" style="animation-duration: {{ section.settings.marquee_speed }}s;">
      {%- for i in (1..4) -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'logo' -%}
            <div class="pt-marquee-item">
              {%- if block.settings.image -%}
                {{ block.settings.image | image_url: width: 150 | image_tag: loading: 'lazy' }}
              {%- else -%}
                <div class="pt-logo-placeholder">{{ 'logo' | placeholder_svg_tag }}</div>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .pt-container { max-width: 1200px; margin: 0 auto 60px; }
  .pt-heading { margin-bottom: 50px; color: rgb(var(--color-foreground)); }
  .pt-grid { display: flex; justify-content: center; gap: 30px; flex-wrap: wrap; }
  .pt-card { background: rgb(var(--color-background)); border-radius: 12px; padding: 30px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); flex: 1; min-width: 300px; max-width: 380px; display: flex; flex-direction: column; border: 1px solid rgba(var(--color-foreground), 0.05); }
  .pt-stars { margin-bottom: 5px; display: flex; gap: 2px; }
  .pt-quote { font-size: 14px; line-height: 1.6; color: rgba(var(--color-foreground), 0.8); margin-bottom: 30px; flex-grow: 1; }
  .pt-card-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 20px; border-top: 1px solid rgba(var(--color-foreground), 0.05); }
  .pt-author-info { display: flex; align-items: center; gap: 12px; }
  .pt-avatar { width: 44px; height: 44px; border-radius: 50%; overflow: hidden; flex-shrink: 0; background: rgba(var(--color-foreground), 0.1); }
  .pt-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .pt-meta { display: flex; flex-direction: column; }
  .pt-name { font-size: 14px; font-weight: 700; color: rgb(var(--color-foreground)); margin: 0;}
  .pt-title { font-size: 11px; margin-top: 2px; }
  .pt-company-logo img { max-height: 25px; width: auto; display: block; }
  .pt-marquee-wrapper { width: 100%; overflow: hidden; padding: 30px 0; border-top: 1px solid rgba(var(--color-foreground), 0.05); }
  .pt-marquee-track { display: flex; align-items: center; width: max-content; animation: pt-scroll linear infinite; gap: 80px; }
  .pt-marquee-item img { height: 35px; width: auto; object-fit: contain;  transition: 0.3s; }
  .pt-marquee-item:hover img { filter: grayscale(0); opacity: 1; }
  .pt-logo-placeholder svg { height: 40px; width: 80px; fill: rgba(var(--color-foreground), 0.2); }
  @keyframes pt-scroll { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  @media (max-width: 768px) { .pt-grid { flex-direction: column; align-items: center; } .pt-card { width: 100%; } .pt-marquee-track { gap: 40px; } }
</style>