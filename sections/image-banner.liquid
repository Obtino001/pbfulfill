{%- style -%}
  /* Inlined Critical Banner CSS */
  .banner { display: flex; position: relative; flex-direction: column; isolation: isolate; height: 90vh; overflow: hidden; }
  .banner__media { height: 100%; width: 100%; position: absolute; left: 0; top: 0; }
  .banner__media img { width: 100%; height: 100%; object-fit: cover; }
  .banner__content { display: flex; position: relative; width: 100%; z-index: 2; padding: 2rem; align-items: center; justify-content: center; }
  .banner__box { padding: 4rem 2rem; width: 100%; word-wrap: break-word; z-index: 1; text-align: center; }
  @media screen and (min-width: 750px) {
    .banner { flex-direction: row; }
    .banner__content { padding: 5rem; }
  }

  #Banner-{{ section.id }}::after {
    opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  }

  /* Desktop Positioning */
  .section-{{ section.id }}-padding .banner__media {
    top: {{ section.settings.custom_top_offset }}%;
  }

  .section-{{ section.id }}-padding .banner__content {
    margin-top: {{ section.settings.mt_percent }}%;
  }

  /* Mobile Positioning */
  @media screen and (max-width: 749px) {
    .section-{{ section.id }}-padding .banner__media {
      top: {{ section.settings.custom_top_offset_mobile }}%;
    }
    .section-{{ section.id }}-padding .banner__content {
      margin-top: {{ section.settings.mt_percent_mobile }}%;
    }
  }

  {%- if section.settings.image_height == 'adapt' and section.settings.image != blank -%}
    #Banner-{{ section.id }}::before,
    #Banner-{{ section.id }} .banner__media::before {
      padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
      content: '';
      display: block;
    }
  {%- endif -%}
{%- endstyle -%}

<div id="Banner-{{ section.id }}" data-priority-hero class="banner section-{{ section.id }}-padding banner--{{ section.settings.image_height }}{% if section.settings.show_text_below %} banner--mobile-bottom{% endif %}">
  
  {%- if section.settings.image != blank -%}
    <div class="banner__media media">
      {%- if section.settings.mobile_image != blank -%}
        <picture>
          <source 
            media="(max-width: 749px)" 
            srcset="{{ section.settings.mobile_image | image_url: width: 375 }} 375w, {{ section.settings.mobile_image | image_url: width: 550 }} 550w, {{ section.settings.mobile_image | image_url: width: 750 }} 750w"
            sizes="100vw"
          >
          {{ section.settings.image | image_url: width: 1500 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
            class: 'banner__media-image'
          }}
        </picture>
      {%- else -%}
        {{ section.settings.image | image_url: width: 1500 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '375, 550, 750, 1100, 1500',
          class: 'banner__media-image'
        }}
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="banner__media media placeholder">
      {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
    </div>
  {%- endif -%}

  <div class="banner__content banner__content--{{ section.settings.desktop_content_position }} page-width">
    <div class="banner__box content-container color-{{ section.settings.color_scheme }} gradient">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h1 class="banner__heading inline-richtext {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </h1>
          {%- when 'text' -%}
            <div class="banner__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
              <p>{{ block.settings.text }}</p>
            </div>
          {%- when 'buttons' -%}
            <div class="banner__buttons" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a href="{{ block.settings.button_link_1 }}" class="button button--primary">{{ block.settings.button_label_1 | escape }}</a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a href="{{ block.settings.button_link_2 }}" class="button button--secondary" style="color: #ffffff; border-color: #ffffff !important;">{{ block.settings.button_label_2 | escape }}</a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Desktop Positioning"
    },
    {
      "type": "range",
      "id": "custom_top_offset",
      "label": "Image Top Offset (%)",
      "min": -50,
      "max": 50,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "mt_percent",
      "label": "Content Top Offset (%)",
      "min": -50,
      "max": 50,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "Mobile Positioning"
    },
    {
      "type": "range",
      "id": "custom_top_offset_mobile",
      "label": "Mobile Image Top Offset (%)",
      "min": -50,
      "max": 50,
      "step": 1,
      "default": 0
    },
    {
      "type": "range",
      "id": "mt_percent_mobile",
      "label": "Mobile Content Top Offset (%)",
      "min": -50,
      "max": 50,
      "step": 1,
      "default": 0
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image-banner.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile Image (Optional)"
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "t:sections.image-banner.settings.image_overlay_opacity.label",
      "default": 0
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        { "value": "adapt", "label": "Adapt to image" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium",
      "label": "Banner height"
    },
    {
      "type": "select",
      "id": "desktop_content_position",
      "options": [
        { "value": "top-center", "label": "Top center" },
        { "value": "middle-center", "label": "Middle center" },
        { "value": "bottom-center", "label": "Bottom center" }
      ],
      "default": "middle-center",
      "label": "Desktop content position"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_text_below",
      "default": true,
      "label": "t:sections.image-banner.settings.show_text_below.label"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        { "type": "inline_richtext", "id": "heading", "default": "Image Banner", "label": "Heading" },
        { "type": "select", "id": "heading_size", "options": [
            { "value": "h2", "label": "Small" },
            { "value": "h1", "label": "Medium" },
            { "value": "h0", "label": "Large" }
          ], "default": "h1", "label": "Heading size" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "inline_richtext", "id": "text", "default": "Give customers details about the banner image.", "label": "Description" }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "settings": [
        { "type": "text", "id": "button_label_1", "label": "First button label", "default": "Button label" },
        { "type": "url", "id": "button_link_1", "label": "First button link" },
        { "type": "text", "id": "button_label_2", "label": "Second button label" },
        { "type": "url", "id": "button_link_2", "label": "Second button link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.image-banner.presets.name",
      "blocks": [
        { "type": "heading" },
        { "type": "text" },
        { "type": "buttons" }
      ]
    }
  ]
}
{% endschema %}