{%- style -%}
  .wc-section-{{ section.id }} { 
    background-color: {{ section.settings.bg_color }}; 
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .wc-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .wc-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .wc-heading {
    text-align: center;
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 40px;
    color: rgb(var(--color-foreground));
  }

  /* --- Card Base Styles --- */
  .wc-card {
    background: #ffffff;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .wc-image-wrapper {
    aspect-ratio: 1.5 / 1;
    overflow: hidden;
    background: #f4f4f4;
  }

  .wc-img, .wc-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
.wc-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    justify-content: center;
    align-items: center;
}

  .wc-label {
    font-size: 18px;
    font-weight: 700;
    margin: 0 0 12px 0;
    color: #535862;
    text-align: center;
  }

.wc-desc {
    font-size: 14px;
    line-height: 1.5;
    color: #475467;
    margin: 0;
    text-align: center;
}

  /* --- Desktop Grid Layout --- */
  @media screen and (min-width: 769px) {
    .wc-mobile-wrapper { display: none !important; }
    
    .wc-desktop-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr); 
      gap: 24px;
    }
    .wc-span-3 { grid-column: span 3; }
    .wc-span-2 { grid-column: span 2; }
  }

  /* --- Mobile Swiper Layout & Custom Controls --- */
  @media screen and (max-width: 768px) {
    .wc-desktop-grid { display: none !important; }
    
    .wc-heading { font-size: 26px; margin-bottom: 30px; }
    
    .wc-mobile-wrapper {
      display: block;
      overflow: visible !important; /* Allows peeking without clipping */
      clip-path: inset(-100px 0px -100px 0px); /* Prevents vertical shadow clipping but hides horizontal overflow */
      padding-bottom: 10px;
    }

    .wc-swiper-{{ section.id }} {
      overflow: visible !important; /* Key for peeking effect */
    }

    .wc-swiper-{{ section.id }} .swiper-slide {
      height: auto; 
      width: 85%; /* Controls how much of the next card is visible */
    }

    /* Layout for Nav and Pagination */
    .wc-controls-{{ section.id }} {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 15px; 
      margin-top: 30px;
    }

    /* Colored Nav Buttons */
    .wc-nav-prev-{{ section.id }},
    .wc-nav-next-{{ section.id }} {
      width: 48px;
      height: 48px;
      background-color: {{ section.settings.slider_color }};
      color: #fff;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: opacity 0.3s ease, transform 0.2s ease;
      flex-shrink: 0;
    }

    .wc-nav-prev-{{ section.id }}:active,
    .wc-nav-next-{{ section.id }}:active {
      transform: scale(0.95);
    }

    .wc-nav-prev-{{ section.id }}.swiper-button-disabled,
    .wc-nav-next-{{ section.id }}.swiper-button-disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }

    /* White Pill Container for Bullets */
    .wc-pagination-{{ section.id }} {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      background: #ffffff;
      padding: 12px 20px;
      border-radius: 40px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05); 
      width: auto !important; 
      position: static !important; 
    }

    /* Custom Swiper Bullets (Ovals) */
    .wc-pagination-{{ section.id }} .swiper-pagination-bullet {
      width: 14px;
      height: 6px;
      background: #EAEAEA; 
      border-radius: 10px;
      opacity: 1;
      margin: 0 !important;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      cursor: pointer;
    }

    .wc-pagination-{{ section.id }} .swiper-pagination-bullet-active {
      background: {{ section.settings.slider_color }};
      width: 16px; 
    }
  }
{%- endstyle -%}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<div class="wc-section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="wc-wrapper">
    
    {%- if section.settings.heading != blank -%}
      <h2 class="h1">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="wc-desktop-grid">
      {%- for block in section.blocks -%}
        {%- assign grid_class = 'wc-span-2' -%}
        {%- if forloop.index <= 2 -%}{%- assign grid_class = 'wc-span-3' -%}{%- endif -%}
        
        <div class="wc-card {{ grid_class }}" {{ block.shopify_attributes }}>
          <div class="wc-image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'wc-img', alt: block.settings.label }}
            {%- else -%}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'wc-placeholder' }}
            {%- endif -%}
          </div>
          <div class="wc-content">
            <h3 class="wc-label">{{ block.settings.label | escape }}</h3>
            {%- if block.settings.desc != blank -%}
              <p class="wc-desc">{{ block.settings.desc }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>

    <div class="wc-mobile-wrapper">
      <div class="swiper wc-swiper-{{ section.id }}">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="wc-card">
                <div class="wc-image-wrapper">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'wc-img', alt: block.settings.label }}
                  {%- else -%}
                    {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'wc-placeholder' }}
                  {%- endif -%}
                </div>
                <div class="wc-content">
                  <h3 class="wc-label">{{ block.settings.label | escape }}</h3>
                  {%- if block.settings.desc != blank -%}
                    <p class="wc-desc">{{ block.settings.desc }}</p>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="wc-controls-{{ section.id }}">
        <div class="wc-nav-prev-{{ section.id }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </div>
        <div class="wc-pagination-{{ section.id }}"></div>
        <div class="wc-nav-next-{{ section.id }}">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const initWcSwiper = () => {
      let swiperOptions = {
        slidesPerView: 'auto',      // Allows CSS width to dictate size
        centeredSlides: false,      // Keeps alignment to the left
        spaceBetween: 16,
        grabCursor: true,
        slidesOffsetBefore: 20,     // Adds initial left gutter
        slidesOffsetAfter: 20,      // Adds final right gutter
        pagination: {
          el: '.wc-pagination-{{ section.id }}',
          clickable: true,
        },
        navigation: {
          nextEl: '.wc-nav-next-{{ section.id }}',
          prevEl: '.wc-nav-prev-{{ section.id }}',
        },
        breakpoints: {
          769: {
            enabled: false // Swiper turns off completely on desktop to allow Grid to function
          }
        }
      };

      {% if section.settings.enable_autoplay %}
        swiperOptions.autoplay = {
          delay: {{ section.settings.autoplay_delay | times: 1000 }},
          disableOnInteraction: false, // Prevents autoplay from stopping after user swipes
        };
      {% endif %}

      new Swiper('.wc-swiper-{{ section.id }}', swiperOptions);
    };

    if (typeof Swiper !== 'undefined') {
      initWcSwiper();
    } else {
      const swiperScript = document.querySelector('script[src*="swiper-bundle"]');
      if(swiperScript) {
        swiperScript.addEventListener('load', initWcSwiper);
      }
    }
  });
</script>

{% schema %}
{
  "name": "Warehouse Capabilities",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "background-1" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Warehouse Capabilities" },
    { "type": "color", "id": "bg_color", "label": "Background Override", "default": "#FAFAFA" },
    {
      "type": "header",
      "content": "Mobile Slider Settings"
    },
    {
      "type": "color",
      "id": "slider_color",
      "label": "Controls Accent Color",
      "default": "#2961BE"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable Auto Scroll",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Auto Scroll Delay",
      "default": 3
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Capability Card",
      "limit": 5,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Title", "default": "Inventory & Storage" },
        { "type": "textarea", "id": "desc", "label": "Description", "default": "We securely store your products in our organized facilities." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Warehouse Capabilities",
      "blocks": [
        { "type": "item", "settings": { "label": "Inventory & Storage Management", "desc": "We securely store your products in our organized, climate-controlled facilities while keeping your inventory updated in real time." }},
        { "type": "item", "settings": { "label": "Local Return Handling", "desc": "We process customer returns through nearby regional centers, reducing shipping costs and turnaround time." }},
        { "type": "item", "settings": { "label": "Pick & Pack Order Fulfillment", "desc": "Our team accurately selects the right items from your inventory and packs them securely according to your specifications." }},
        { "type": "item", "settings": { "label": "Labeling & Packaging", "desc": "We apply accurate shipping labels and carefully package to meet requirements and protect your products in transit." }},
        { "type": "item", "settings": { "label": "Same-day or 1-3 Day Delivery", "desc": "We partner with fast, reliable carriers to deliver your orders within the U.S. as quickly as same day or within 1-3 days." }}
      ]
    }
  ]
}
{% endschema %}