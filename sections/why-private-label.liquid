{%- style -%}
  .pl-matters-{{ section.id }} { 
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    background-color: rgb(var(--color-background)); 
  }
  @media screen and (min-width: 750px) {
    .pl-matters-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .pl-container { 
    max-width: 1200px; 
    margin: 0 auto; 
    padding: 0 2rem; 
    text-align: center; 
  }
  .pl-title { 
    font-size: 3.2rem; 
    color: rgb(var(--color-foreground)); 
    margin-top: 0;
    margin-bottom: 5rem; 
    font-weight: 700; 
  }
  .pl-grid { 
    display: flex; 
    gap: 2.4rem; 
    justify-content: center; 
    flex-wrap: wrap; 
  }
  .pl-card { 
    background: rgb(var(--color-background)); 
    border-radius: 12px; 
    padding: 3rem 2rem; 
    flex: 1; 
    min-width: 30rem; 
    max-width: 35rem;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    box-shadow: 0px 24px 48px -12px rgba(10, 13, 18, 0.18);
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
  }
  .pl-card:hover { 
    transform: translateY(-1rem) scale(1.02); 
    box-shadow: 0 2rem 4rem rgba(0,0,0,0.12); 
    z-index: 2; 
  }
  .pl-image-wrapper { 
    width: 100%; 
    height: 16rem; 
    margin-bottom: 2rem; 
    display: flex; 
    justify-content: center; 
    align-items: center; 
  }
  .pl-image-wrapper img, .pl-image-wrapper svg { 
    max-width: 100%; 
    max-height: 100%; 
    object-fit: contain; 
  }
  .pl-text { 
    color: rgba(var(--color-foreground), 0.75); 
    font-size: 1.6rem; 
    font-weight: 600; 
    line-height: 1.5; 
    margin: 0; 
    max-width: 25rem; 
  }
  
  /* Footer Element Styling */
  .pl-footer-wrapper {
    margin-top: 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }


  /* --- Mobile Layout Overrides --- */
  @media (max-width: 768px) { 
    .pl-title {
      font-size: 2.6rem;
      margin-bottom: 3rem;
    }
    .pl-grid {
      gap: 1.6rem;
    }
    .pl-card { 
      min-width: 100%; 
      flex-direction: row; /* Image and text side-by-side */
      align-items: center;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
    } 
  .pl-image-wrapper {
    width: 15rem;
    height: 100px;
    margin-bottom: 0;
    flex-shrink: 0;
}
    .pl-text {
      text-align: left; /* Aligns text left next to the image */
    }
    .pl-footer-wrapper {
      margin-top: 3.5rem;
    }
    .pl-footer-text {
      font-size: 1.3rem;
    }
  }
{%- endstyle -%}

<section class="pl-matters-section pl-matters-{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="pl-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="h1">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    
    <div class="pl-grid">
      {%- for block in section.blocks -%}
        <div class="pl-card" {{ block.shopify_attributes }}>
          <div class="pl-image-wrapper">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: alt: block.settings.text, loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <h3 class="pl-text">{{ block.settings.text | escape }}</h3>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footer_text != blank or section.settings.footer_button_label != blank -%}
      <div class="pl-footer-wrapper">
        {%- if section.settings.footer_text != blank -%}
          <p class="pl-footer-text">{{ section.settings.footer_text | escape }}</p>
        {%- endif -%}

        {%- if section.settings.footer_button_label != blank -%}
          <a href="{{ section.settings.footer_button_link }}" class="button pl-btn-pill {% if section.settings.button_style_secondary %}button--secondary{% else %}button--primary{% endif %}">
            {{ section.settings.footer_button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
    
  </div>
</section>

{% schema %}
{
  "name": "Feature Card Section-3",
  "settings": [
    { 
      "type": "color_scheme", 
      "id": "color_scheme", 
      "label": "Color scheme", 
      "default": "background-1" 
    },
    { 
      "type": "text", 
      "id": "heading", 
      "label": "Heading", 
      "default": "Why Private Label Matters?" 
    },
    {
      "type": "header",
      "content": "Footer Settings"
    },
    { 
      "type": "text", 
      "id": "footer_text", 
      "label": "Footer Text", 
      "default": "Your logo is what turns a product into a business.",
      "info": "Leave blank to hide."
    },
    {
      "type": "text",
      "id": "footer_button_label",
      "label": "Button Label",
      "default": "Return Policy Pages",
      "info": "Leave blank to hide the button."
    },
    {
      "type": "url",
      "id": "footer_button_link",
      "label": "Button Link"
    },
    {
      "type": "checkbox",
      "id": "button_style_secondary",
      "default": true,
      "label": "Use Outline Button Style"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Feature Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "text", "label": "Description", "default": "83% of online shoppers prefer buying from recognizable brands." }
      ]
    }
  ],
  "presets": [
    { 
      "name": "Feature Card Section-3", 
      "blocks": [ 
        { "type": "column" }, 
        { "type": "column" }, 
        { "type": "column" } 
      ] 
    }
  ]
}
{% endschema %}