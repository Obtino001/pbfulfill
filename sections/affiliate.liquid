<div class="affiliate-section-{{ section.id }} color-{{ section.settings.color_scheme }} gradient {{ section.settings.custom_class }}" 
     style="--grid-desktop: {{ section.settings.columns_desktop }}; --bg-image: url('{{ section.settings.bg_image | image_url }}');">
<style>
  .affiliate-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .affiliate-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
  <div class="page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="cfb-heading h1">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="affiliate-cards-grid">
      {%- for block in section.blocks -%}
        <div class="affiliate-card" {{ block.shopify_attributes }}>
          <div class="affiliate-card-image-container">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 400 | image_tag: class: 'affiliate-card-image', loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <h3 class="affiliate-card-title">{{ block.settings.title | escape }}</h3>
          <p class="affiliate-card-description">{{ block.settings.description | escape }}</p>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="affiliate-button-container">
        <a href="{{ section.settings.button_link }}" class="button button--primary">
          {{ section.settings.button_text | escape }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "Feature Card Section-2",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },
    { "type": "text", "id": "custom_class", "label": "Custom CSS class" },
    {
  "type": "range",
  "id": "columns_desktop",
  "min": 1,
  "max": 4,
  "step": 1,
  "default": 3,
  "label": "Number of columns on desktop"
},
    { "type": "image_picker", "id": "bg_image", "label": "Background Image" },
    { "type": "text", "id": "title", "label": "Title", "default": "Become an Affiliate" },
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "Learn More" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
     "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Affiliate Card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Card Image" },
        { "type": "text", "id": "title", "label": "Card Title", "default": "Refer a Friend" },
        { "type": "textarea", "id": "description", "label": "Card Description", "default": "We will reach out to your friend order." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature Card Section-2",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}