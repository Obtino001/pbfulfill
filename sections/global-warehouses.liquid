{% schema %}
{
  "name": "Global Warehouses",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Global Warehouses Matter"
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "Local inventory, global reach — scale without limits."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#4A5568"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon/Image"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Reduce average delivery time by up to 70%."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Global Warehouses",
      "blocks": [
        {
          "type": "feature_card",
          "settings": {
            "text": "Reduce average delivery time by up to 70%."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "text": "Lower return & replacement cost for international orders."
          }
        },
        {
          "type": "feature_card",
          "settings": {
            "text": "Boost customer satisfaction & conversion metrics."
          }
        }
      ]
    }
  ]
}
{% endschema %}

{% style %}
  /* Section Scoped Variables */
  #shopify-section-{{ section.id }} {
    --bg-color: {{ section.settings.bg_color }};
    --text-primary: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .gw-section {
    background-color: var(--bg-color);
    color: var(--text-primary);
  }

  .gw-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Heading */
  .gw-heading {
    text-align: center;
    font-size: 32px;
    font-weight: 700;
    color: #4A5568; 
    margin-bottom: 48px;
    letter-spacing: -0.02em;
  }

  /* Grid Layout */
  .gw-grid {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }

  /* CARD STYLING */
  .gw-card {
    flex: 1;
    min-width: 280px;
    max-width: 360px;
    background: #FFFFFF;
    border-radius: 12px;
    padding: 32px 24px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    
    border: 1px solid #E9EAEB;
    box-shadow: 
      0px 4px 4px -2px #0A0D120A,
      0px 24px 48px -12px #0A0D122E;
      
    transition: transform 0.3s ease;
  }

  .gw-card:hover {
    transform: translateY(-5px);
  }

  /* Image Area */
  .gw-image-wrapper {
    width: 100%;
    height: 140px; 
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gw-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }

  .gw-placeholder-svg {
    width: 120px;
    height: 120px;
    background: #F7FAFC;
    border-radius: 8px;
    color: #CBD5E0;
  }

  /* Card Text */
  .gw-card-text {
    font-size: 16px;
    line-height: 1.5;
    font-weight: 600;
    color: #4A5568;
    margin: 0;
  }

  /* Footer Note */
  .gw-footer-note {
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    color: #718096;
    margin-top: 20px;
    padding: 0 15px;
  }

  /* --- Mobile Adjustments (Matches Screenshot) --- */
  @media (max-width: 768px) {
    .gw-heading {
      font-size: 26px;
      margin-bottom: 32px;
    }
    .gw-grid {
      flex-direction: column;
      align-items: center;
      gap: 16px; /* Tighter gap like screenshot */
    }
    
    /* Change Card to Horizontal Layout */
    .gw-card {
      width: 100%;
      max-width: 100%;
      flex-direction: row; /* Image left, text right */
      padding: 16px 20px; /* Reduced padding for mobile row */
      align-items: center;
      text-align: left; /* Align text to the left */
      gap: 20px; /* Space between image and text */
    }

.gw-image-wrapper {
    width: 16rem;
    height: 10rem;
    margin-bottom: 0;
    flex-shrink: 0;
}
  }
{% endstyle %}

<div class="gw-section" id="global-warehouses-{{ section.id }}">
  <div class="gw-container">
    
    {% if section.settings.heading != blank %}
      <h2 class="gw-heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div class="gw-grid">
      {% for block in section.blocks %}
        <div class="gw-card" {{ block.shopify_attributes }}>
          
          <div class="gw-image-wrapper">
            {% if block.settings.icon != blank %}
              <img 
                src="{{ block.settings.icon | image_url: width: 400 }}" 
                alt="{{ block.settings.icon.alt | escape }}" 
                class="gw-image"
                loading="lazy"
                width="200"
                height="auto"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'gw-placeholder-svg' }}
            {% endif %}
          </div>

          {% if block.settings.text != blank %}
            <h3 class="gw-card-text">{{ block.settings.text | escape }}</h3>
          {% endif %}

        </div>
      {% endfor %}
    </div>

    {% if section.settings.footer_text != blank %}
      <div class="gw-footer-note">
        {{ section.settings.footer_text | escape }}
      </div>
    {% endif %}

  </div>
</div>