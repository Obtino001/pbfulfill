{% schema %}
{
  "name": "Stats Card Animated",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Refund & Claim Policy"
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer Text",
      "default": "Our numbers reflect trust not just volume."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number (e.g. 3 or 2.5)",
          "info": "Enter the raw number (decimals supported). We will append the suffix."
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix (e.g. M+)",
          "default": "M+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Orders Shipped"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Stats Card Animated",
      "blocks": [
        { "type": "stat", "settings": { "number": "3", "suffix": "M+", "label": "Orders Shipped" } },
        { "type": "stat", "settings": { "number": "23", "suffix": "+", "label": "Warehouses Partners" } },
        { "type": "stat", "settings": { "number": "6", "suffix": "K+", "label": "SKUs Sourced" } },
        { "type": "stat", "settings": { "number": "2.5", "suffix": "K+", "label": "Global Clients" } }
      ]
    }
  ]
}
{% endschema %}

<div class="stats-section" id="stats-section-{{ section.id }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  
  {% if section.settings.heading != blank %}
    <h2 class="h1">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="stats-card">
    <div class="stats-grid">
      {% for block in section.blocks %}
        <div class="stat-item" {{ block.shopify_attributes }}>
          <div class="stat-number-wrapper">
            <span class="stat-number" data-target="{{ block.settings.number }}">0</span><span class="stat-suffix">{{ block.settings.suffix }}</span>
          </div>
          <p class="stat-label">{{ block.settings.label }}</p>
        </div>
      {% endfor %}
    </div>
  </div>

  {% if section.settings.footer_text != blank %}
   <div class="pl-footer-wrapper">
      <p class="pl-footer-text">{{ section.settings.footer_text }}</p>
      </div>
  {% endif %}

</div>

<style>
  .stats-section {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 20px;
    padding-right: 20px;
    background-color: {{ section.settings.bg_color }};
    text-align: center;
  }
  @media screen and (min-width: 750px) {
    .stats-section {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .stats-heading {
    font-size: 26px;
    font-weight: 600;
    color: #4a545e;
    margin-bottom: 40px;
  }

  .stats-card {
    background: #f4f8ff; /* Slightly deeper light blue tint to match screenshot */
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05); /* Soft shadow */
    padding: 50px 20px;
    max-width: 1000px;
    margin: 0 auto  40px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  .stat-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .stat-number-wrapper {
    font-size: 42px;
    font-weight: 700;
    color: #2962bd; /* The blue color from your image */
    margin-bottom: 10px;
    display: flex;
    justify-content: center;
    align-items: baseline;
  }

  .stat-label {
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.8);
    font-weight: 600;
    margin: 0;
  }

  .stats-footer {
    margin-top: 30px;
    font-size: 15px;
    color: rgba(var(--color-foreground), 0.8);
    font-weight: 500;
  }

  /* Mobile Responsive - 100% Match */
  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr); /* Forces a 2x2 grid on mobile */
      row-gap: 50px;
      column-gap: 15px;
    }
    .stats-card {
      padding: 40px 15px;
    }
    .stat-number-wrapper {
      font-size: 34px; /* Scaled down to prevent awkward wrapping */
      margin-bottom: 5px;
    }
    .stat-label {
      font-size: 11px; /* Scaled down for mobile fit */
    }
    .stats-heading {
      font-size: 22px;
      margin-bottom: 30px;
    }
  }
</style>

<script>
  (function() {
    const initAnimatedStats = () => {
      // Grab all numbers that haven't been animated yet
      const statNumbers = document.querySelectorAll('.stat-number:not(.is-animated)');
      
      if (statNumbers.length === 0) return;

      const animateValue = (obj) => {
        const targetStr = obj.getAttribute('data-target');
        const target = parseFloat(targetStr);
        
        if (isNaN(target)) {
          obj.innerText = targetStr;
          return;
        }

        const isFloat = targetStr.includes('.');
        let startTimestamp = null;
        const duration = 2000; 

        const step = (timestamp) => {
          if (!startTimestamp) startTimestamp = timestamp;
          const progress = Math.min((timestamp - startTimestamp) / duration, 1);
          
          // Easing function for a smoother slow-down at the end
          const easeProgress = 1 - Math.pow(1 - progress, 4);
          let currentVal = easeProgress * target;
          
          obj.innerText = isFloat ? currentVal.toFixed(1) : Math.floor(currentVal);

          if (progress < 1) {
            window.requestAnimationFrame(step);
          } else {
            obj.innerText = isFloat ? target.toFixed(1) : target; 
          }
        };
        
        window.requestAnimationFrame(step);
      };

      // Set up the observer with a very low threshold so it triggers easily
      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target;
            // Mark as animated so it doesn't run again
            el.classList.add('is-animated');
            animateValue(el);
            // Stop watching this specific element
            obs.unobserve(el); 
          }
        });
      }, { rootMargin: "0px", threshold: 0.1 });

      // Observe each number individually instead of the whole section
      statNumbers.forEach(num => observer.observe(num));
    };

    // 1. Run immediately if the page is already loaded
    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initAnimatedStats();
    } 
    // 2. Otherwise, wait for the DOM to finish loading
    else {
      document.addEventListener("DOMContentLoaded", initAnimatedStats);
    }

    // 3. Force re-run when saving in the Shopify Theme Editor
    document.addEventListener('shopify:section:load', initAnimatedStats);

  })();
</script>