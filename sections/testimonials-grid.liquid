{%- style -%}
  .ts-wrapper-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .ts-wrapper-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

.ts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    align-items: stretch;
    padding-bottom: 50px;
}
.ts-card {
    background: rgb(var(--color-background));
    border-radius: 12px;
    padding: 30px;
    border: none; /* Removed the conflicting border */
    box-shadow: 0px 24px 48px -12px rgba(10, 13, 18, 0.18);
    display: flex;
    flex-direction: column; 
    height: 100%; 
    transition: transform 0.3s ease;
  }

  .ts-heading {
    margin-bottom: 50px;
  }

  .ts-stars {
    margin-bottom: 15px;
    display: flex;
    gap: 2px;
  }
  .ts-star-img {
    height: auto;
    width: {{ section.settings.star_image_width }}px;
    object-fit: contain;
  }

  .ts-quote {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.8);
    margin-bottom: 25px;
  }

  .ts-author {
    display: flex;
    align-items: center;
    gap: 15px;
    margin-top: auto; /* THIS FIXES IT: Pushes the author block to the absolute bottom of the card */
  }

  .ts-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    background: #eee;
    flex-shrink: 0;
  }

  .ts-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ts-meta {
    display: flex;
    flex-direction: column;
  }

  .ts-name {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: rgb(var(--color-foreground));
  }

  .ts-title {
    font-size: 13px;
    opacity: 0.7;
    color: rgb(var(--color-foreground));
  }

  @media (max-width: 768px) {
    .ts-grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding: 20px 0; 
      gap: 15px;
      scroll-snap-type: x mandatory;
      scrollbar-width: none; 
      -ms-overflow-style: none; 
      align-items: stretch; /* Mobile: Forces horizontal scroll items to be equal height */
    }

    .ts-grid::-webkit-scrollbar {
      display: none; 
    }

    .ts-card {
      flex: 0 0 85%;
      scroll-snap-align: center;
      height: auto; /* Allows the parent container's 'stretch' to dictate the height */
    }
    
    .ts-grid::after {
      content: '';
      flex: 0 0 10px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient ts-wrapper ts-wrapper-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="ts-heading h1 center">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ts-grid">
      {%- for block in section.blocks -%}
        <div class="ts-card" {{ block.shopify_attributes }}>
          <div class="ts-stars">
            {% if section.settings.star_image != blank %}
              {{ section.settings.star_image | image_url: width: 400 | image_tag: class: 'ts-star-img', loading: 'lazy', alt: section.settings.star_image_alt | default: "" }}
            {% else %}
              {%- for i in (1..block.settings.stars) -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#F5C518">
                  <path d="M12 17.27L18.18 21L16.54 13.97L22 9.24L14.81 8.63L12 2L9.19 8.63L2 9.24L7.46 13.97L5.82 21L12 17.27Z"/>
                </svg>
              {%- endfor -%}
            {% endif %}
          </div>
          
          <div class="ts-quote">
            {{ block.settings.quote }}
          </div>

          <div class="ts-author">
            <div class="ts-avatar">
              {%- if block.settings.author_image != blank -%}
                {{ block.settings.author_image | image_url: width: 100 | image_tag: loading: 'lazy' }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="ts-meta">
              <h3 class="ts-name">{{ block.settings.author_name }}</h3>
              <span class="ts-title">{{ block.settings.author_title }}</span>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testimonial Grid",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color Scheme", "default": "background-1" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "What Sellers Say" },
    { "type": "header", "content": "Rating Icons" },
    {
      "type": "image_picker",
      "id": "star_image",
      "label": "Custom Rating Image (Optional)",
      "info": "Replaces the star SVGs. Useful for uploading a custom pill/badge image."
    },
    {
      "type": "text",
      "id": "star_image_alt",
      "label": "Rating Image Alt Text"
    },
    {
      "type": "range",
      "id": "star_image_width",
      "min": 50,
      "max": 250,
      "step": 5,
      "unit": "px",
      "label": "Rating Image Width",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "range", "id": "stars", "label": "Stars", "min": 1, "max": 5, "default": 5 },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Excellent service!" },
        { "type": "image_picker", "id": "author_image", "label": "Photo" },
        { "type": "text", "id": "author_name", "label": "Name", "default": "Florence Shaw" },
        { "type": "text", "id": "author_title", "label": "Title", "default": "Canada Dropshipper" }
      ]
    }
  ],
  "presets": [{ "name": "Testimonial Grid" }]
}
{% endschema %}