{% schema %}
{
  "name": "Clients Feedback",
  "settings": [
    { "type": "header", "content": "Section Appearance" },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card Color Scheme",
      "default": "scheme-2"
    },
    { "type": "header", "content": "Padding Settings" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Top Pad", "default": 50 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Bottom Pad", "default": 50 },
    { "type": "range", "id": "padding_top_mobile", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Mobile Top", "default": 30 },
    { "type": "range", "id": "padding_bottom_mobile", "min": 0, "max": 100, "step": 2, "unit": "px", "label": "Mobile Bottom", "default": 30 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Client Feedback" },
    { "type": "header", "content": "Bottom Button" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "Learn More" },
    { "type": "url", "id": "button_link", "label": "Button Link" },
    { "type": "header", "content": "Autoplay Settings" },
    { "type": "range", "id": "autoplay_speed", "min": 1, "max": 10, "step": 1, "unit": "sec", "label": "Time between slides", "default": 3 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial Card",
      "settings": [
        { "type": "image_picker", "id": "avatar", "label": "User Avatar" },
        { "type": "text", "id": "name", "label": "Customer Name", "default": "John Doe" },
        { "type": "textarea", "id": "feedback", "label": "Feedback Text", "default": "Great service! Highly recommended." },
        { "type": "image_picker", "id": "stars", "label": "Star Rating Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Clients Feedback",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}


<div class="cfb-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" id="cfb-{{ section.id }}" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}">
  {% if section.settings.heading != blank %}
    <h2 class="cfb-heading h1" style="text-align: center; margin-bottom: 40px;">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="swiper cfb-swiper">
    <div class="swiper-wrapper cfb-wrapper">
      {% for block in section.blocks %}
        <div class="swiper-slide cfb-card color-{{ section.settings.card_color_scheme }} gradient">
          {% if block.settings.avatar != blank %}
            <div class="cfb-avatar-wrap">
              {{ block.settings.avatar | image_url: width: 200 | image_tag: class: 'cfb-avatar', loading: 'lazy' }}
            </div>
          {% endif %}
          <h3 class="cfb-name">{{ block.settings.name }}</h3>
          <div class="cfb-text">{{ block.settings.feedback }}</div>
          {% if block.settings.stars != blank %}
            <div class="cfb-stars">
              {{ block.settings.stars | image_url: width: 200 | image_tag: loading: 'lazy' }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>

  {% if section.settings.button_label != blank %}
    <div class="cfb-btn-wrapper">
      <a href="{{ section.settings.button_link }}" class="button button--primary">
        {{ section.settings.button_label }}
      </a>
    </div>
  {% endif %}
</div>

<style>
  .section-{{ section.id }}-padding { 
    padding-top: {{ section.settings.padding_top_mobile }}px; 
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px; 
  }
  @media screen and (min-width: 750px) { 
    .section-{{ section.id }}-padding { 
      padding-top: {{ section.settings.padding_top }}px; 
      padding-bottom: {{ section.settings.padding_bottom }}px; 
    } 
  }

/* ===================================================================
   7. Clients Feedback Section
   =================================================================== */
.cfb-section {
  width: 100%;
  overflow: hidden;
}

.cfb-swiper {
  width: 100%;
  padding-top: 15px; /* Gives room for the hover animation */
  padding-bottom: 40px; /* Space for the drop shadow */
  overflow: hidden;
}

/* Base Card Styles */
.cfb-card {
  width: 270px; /* Default Mobile Width */
  max-width: 85vw;
  border-radius: 40px;
  padding: 32px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 24px;
  border: 1px solid #E9EAEB;
  background: rgb(var(--color-background));
  box-shadow: 0px 4px 4px -2px #0A0D120A, 0px 24px 48px -12px #0A0D122E;
  transition: transform 0.3s ease;
  height: auto; 
}

.cfb-card:hover {
  transform: translateY(-5px);
}

.cfb-avatar-wrap {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  margin: 0;
}

.cfb-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cfb-name {
  font-family: var(--font-heading-family);
  font-size: 20px;
  font-weight: 700;
  color: rgb(var(--color-foreground));
  margin: 0;
}

.cfb-text {
  font-family: var(--font-body-family);
  font-size: 16px;
  line-height: 1.6;
  color: rgba(var(--color-foreground), 0.75);
  margin: 0;
  margin-bottom: auto;
}

.cfb-stars {
  margin-top: 0;
}

.cfb-stars img {
  height: 20px;
  width: auto;
  display: block;
}

.cfb-btn-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20px;
  position: relative;
  z-index: 10;
}

/* Desktop Sizing Override */
@media screen and (min-width: 750px) {
  .cfb-card {
    width: 600px;
  }
}
</style>


<script>
document.addEventListener('DOMContentLoaded', function () {
  const sectionNode = document.querySelector('#cfb-{{ section.id }}');
  const speed = parseInt(sectionNode.getAttribute('data-speed')) || 3000;

  const feedbackSwiper = new Swiper('.cfb-swiper', {
    slidesPerView: 'auto',
    spaceBetween: 15, // Gap on mobile
    grabCursor: true,
    centeredSlides: true,
    loop: true,
    autoplay: {
      delay: speed, // Uses the customizer setting
      disableOnInteraction: false, // Keeps playing after they manually swipe
      pauseOnMouseEnter: true // Pauses so they can read the text
    },
    breakpoints: {
      750: {
        spaceBetween: 30 // Gap on desktop
      }
    }
  });
});
</script>