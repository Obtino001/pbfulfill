{% schema %}
{
  "name": "Sourcing Team Section",
  "settings": [
    { "type": "text", "id": "title", "label": "Section Title", "default": "Our Sourcing Team" },
    { "type": "textarea", "id": "main_text", "label": "Main Text", "default": "Our sourcing experts are based in Yiwu & Guangzhou, fluent in English, and experienced in factory auditing" },
    { "type": "text", "id": "btn_text", "label": "Button Text", "default": "Meet the Team" },
    { "type": "url", "id": "link", "label": "Button Link" },
    { "type": "header", "content": "Images" },
    { "type": "image_picker", "id": "box_image", "label": "1. Box/Grid Pattern Image" },
    { "type": "image_picker", "id": "rainbow_image", "label": "2. Rainbow/Glow Image" },
    { "type": "image_picker", "id": "people_image", "label": "3. People/Team Image" },
    { "type": "image_picker", "id": "bg_image_right", "label": "4. Right Side Background Image" },
    { "type": "header", "content": "Colors & Spacing" },
    { "type": "color", "id": "grad_1", "label": "Gradient Top", "default": "#3E74B9" },
    { "type": "color", "id": "grad_2", "label": "Gradient Bottom", "default": "#5DA8D5" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    },
    { "type": "range", "id": "container_width", "min": 800, "max": 1400, "step": 20, "unit": "px", "label": "Max Width", "default": 1000 }
  ],
  "presets": [{ "name": "Sourcing Team Section" }]
}
{% endschema %}

<style>
  .st-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 20px;
    padding-right: 20px;
    font-family: 'Inter', sans-serif;
  }
  @media screen and (min-width: 750px) {
    .st-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .st-card {
    display: flex;
    border-radius: 24px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    min-height: 420px;
  }
  
  /* Left Side Content Area */
  .st-content {
    flex: 1.2;
    padding: 60px;
    text-align: left;
    position: relative; /* Establish stacking context */
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: white;
    overflow: hidden;
    /* The Blue Gradient Background */
    background: linear-gradient(135deg, {{ section.settings.grad_1 }}, {{ section.settings.grad_2 }});
    z-index: 1;
  }

.st-grid-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-size: 50%;
    z-index: 1;
    pointer-events: none;
    display: inline-block !important;
}
  /* 2. Rainbow/Glow Image */
  .st-rainbow-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    pointer-events: none;
    display: block !important;
  }

  /* Text & Button (Must be on top) */
  .st-text-wrapper {
    position: relative;
    z-index: 10; /* Highest priority */
  }
  .st-text {
    font-size: 28px;
    line-height: 1.3;
    font-weight: 500;
    margin-bottom: 35px;
  }


  /* Right Side Image Area */
  .st-people-wrapper {
    flex: 1;
    position: relative;
    background-size: cover;
    background-position: center;
  }
  .st-people-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 768px) {
    .st-card { flex-direction: column; min-height: auto; border-radius: 20px; }
    .st-people-wrapper { display: none; } /* Or set height if you want it shown on mobile */
    .st-content { padding: 50px 30px; }
    .st-text { font-size: 24px; }
  }
</style>

<div class="st-section-{{ section.id }}">
  <div class="st-container page-width">
    {% if section.settings.title != blank %}
      <h2 class="h1">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="st-card">
      
      <div class="st-content">
        
        {% if section.settings.box_image != blank %}
          <div class="st-grid-pattern" style="background-image: url('{{ section.settings.box_image | image_url }}');"></div>
        {% endif %}

        {% if section.settings.rainbow_image != blank %}
          <div class="st-rainbow-overlay" style="background-image: url('{{ section.settings.rainbow_image | image_url }}');"></div>
        {% endif %}

        <div class="st-text-wrapper">
          <div class="st-text">{{ section.settings.main_text }}</div>
          {% if section.settings.btn_text != blank %}
            <a href="{{ section.settings.link }}" class="button button--secondary" style="color: #ffffff; border-color: #ffffff !important;">{{ section.settings.btn_text }}</a>
          {% endif %}
        </div>

      </div>

      <div class="st-people-wrapper" 
           style="{% if section.settings.bg_image_right != blank %}background-image: url('{{ section.settings.bg_image_right | image_url }}');{% endif %}">
        {% if section.settings.people_image != blank %}
          <img src="{{ section.settings.people_image | image_url: width: 1000 }}" alt="Team" class="st-people-img" loading="lazy">
        {% endif %}
      </div>

    </div>
  </div>
</div>