{%- style -%}
  /* We keep ONLY the dynamic Shopify settings here as CSS variables */
  .ka-section-{{ section.id }} { 
    --bg-color: {{ section.settings.bg_color }}; 
    --pt: {{ section.settings.pt }}px; 
    --pb: {{ section.settings.pb }}px; 
    --container-width: {{ section.settings.container_width }}px;
    --card-radius: {{ section.settings.card_radius }}px;
    --active-border: {{ section.settings.active_border_color }};
  }
{%- endstyle -%}

<div class="ka-section-{{ section.id }} ka-custom-section color-{{ section.settings.color_scheme }} gradient">
  <div class="ka-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="ka-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="ka-grid">
      {%- for block in section.blocks -%}
        <div class="ka-card" onclick="this.classList.toggle('is-active')" {{ block.shopify_attributes }}>
          <div class="ka-icon-wrapper">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.title, class: 'ka-icon' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'ka-icon' }}
            {%- endif -%}
          </div>
          
          <div class="ka-content">
            <h3 class="ka-title">{{ block.settings.title | escape }}</h3>
            <div class="ka-desc-wrapper">
              <div class="ka-desc-inner">
                <p class="ka-desc">{{ block.settings.desc | escape }}</p>
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collapsible Card Section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "background-1" },
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Key Advantages" },
    { "type": "header", "content": "Layout & Spacing" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "transparent" },
    { "type": "range", "id": "pt", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Top", "default": 60 },
    { "type": "range", "id": "pb", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Padding Bottom", "default": 60 },
    { "type": "range", "id": "container_width", "min": 800, "max": 1400, "step": 20, "unit": "px", "label": "Max Width", "default": 1000 },
    { "type": "header", "content": "Card Styling" },
    { "type": "color", "id": "active_border_color", "label": "Highlight Color", "default": "#2563EB" },
    { "type": "range", "id": "card_radius", "min": 4, "max": 30, "step": 1, "unit": "px", "label": "Corner Radius", "default": 16 }
  ],
  "blocks": [
    {
      "type": "advantage",
      "name": "Card",
      "settings": [
        { "type": "image_picker", "id": "icon", "label": "Main Illustration" },
        { "type": "text", "id": "title", "label": "Title", "default": "Access to Verified Factories" },
        { "type": "textarea", "id": "desc", "label": "Hidden Description", "default": "We ensure you maintain full control over your margins." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collapsible Card Section",
      "blocks": [
        { "type": "advantage", "settings": { "title": "Access to Verified Factories Only" } },
        { "type": "advantage", "settings": { "title": "MOQ Flexibility for Sellers" } },
        { "type": "advantage", "settings": { "title": "Expert-Level Negotiation" } },
        { "type": "advantage", "settings": { "title": "Sample Testing Before Bulk" } }
      ]
    }
  ]
}
{% endschema %}