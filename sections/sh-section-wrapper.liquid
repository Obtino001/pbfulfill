          "default": "The fulfillment flow is seamless. Pick, pack, labeling—everything is professional and accurate."
        },
        {
          "type": "image_picker",
          "id": "user_photo",
          "label": "User Photo"
        },
        {
          "type": "text",
          "id": "user_name",
          "label": "User Name",
          "default": "Stefan Sears"
        },
        {
          "type": "text",
          "id": "user_title",
          "label": "User Title",
          "default": "US DTC Brand Owner"
