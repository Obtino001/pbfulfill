
{% schema %}
{
  "name": "How it Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why Choose Us?"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Heading Font Size",
      "default": 36
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "Card Color Scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Padding Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step Card",
      "settings": [
        { "type": "text", "id": "step_number", "label": "Step Number", "default": "1" },
        { "type": "text", "id": "title", "label": "Title", "default": "Send a Request" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Share your target market and desired product." },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "card_link", "label": "Card Link (Optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "How it Works Grid",
      "blocks": [
        { "type": "step", "settings": { "step_number": "1", "title": "Send a Request" } },
        { "type": "step", "settings": { "step_number": "2", "title": "Local Product Sourcing" } },
        { "type": "step", "settings": { "step_number": "3", "title": "Private Label" } }
      ]
    }
  ]
}
{% endschema %}

<div class="hiw-section section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient" style="--heading-size: {{ section.settings.heading_size }}px;">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="h1">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="hiw-grid">
      {% for block in section.blocks %}
        {%- liquid 
          assign card_tag = 'div'
          if block.settings.card_link != blank
            assign card_tag = 'a'
          endif
        -%}

        <{{ card_tag }} 
          {% if block.settings.card_link != blank %}href="{{ block.settings.card_link }}"{% endif %}
          class="hiw-card color-{{ section.settings.card_color_scheme }} gradient {% if block.settings.card_link != blank %} hiw-card--link{% endif %}" 
          {{ block.shopify_attributes }}
        >
          <div class="hiw-content">
            <div class="hiw-number">{{ block.settings.step_number }}</div>
            <h3 class="hiw-title">{{ block.settings.title }}</h3>
            <p class="hiw-text">{{ block.settings.text }}</p>
          </div>
          
          {% if block.settings.image != blank %}
            <div class="hiw-image-wrapper">
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'hiw-image' }}
            </div>
          {% endif %}
        </{{ card_tag }}>
      {% endfor %}
    </div>
  </div>
</div>

<style>
.section-{{ section.id }}-padding { 
  padding-top: {{ section.settings.padding_top_mobile }}px; 
  padding-bottom: {{ section.settings.padding_bottom_mobile }}px; 
}

/* =========================================================
   MOBILE ONLY DESIGN (Figma Mockup)
   ========================================================= */
@media screen and (max-width: 749px) {
  .hiw-heading {
    text-align: center;
    margin-bottom: 24px;
  }
  .hiw-grid {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .hiw-card {
    display: flex;
    flex-direction: row;
    align-items: center;
    background-color: #ffffff !important;
    border-radius: 12px !important;
    padding: 12px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.06);
    gap: 16px;
    border: none !important;
  }
  /* Alternating layout for even cards */
  .hiw-card:nth-child(even) {
    flex-direction: row-reverse;
  }
  .hiw-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  /* Hide number on mobile as per Figma */
  .hiw-number {
    display: none !important;
  }
  .hiw-title {
    font-size: 16px !important;
    font-weight: 700 !important;
    margin: 0 0 6px 0 !important;
    color: #333 !important;
    line-height: 1.2 !important;
  }
  .hiw-text {
    font-size: 13px !important;
    margin: 0 !important;
    color: #666 !important;
    line-height: 1.4 !important;
  }
  .hiw-image-wrapper {
    width: 40%;
    aspect-ratio: 1;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
  }
  .hiw-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
}

/* =========================================================
   DESKTOP PRESERVATION
   ========================================================= */
@media screen and (min-width: 750px) { 
  .section-{{ section.id }}-padding { 
    padding-top: {{ section.settings.padding_top }}px; 
    padding-bottom: {{ section.settings.padding_bottom }}px; 
  } 
  /* This ensures the new .hiw-content wrapper doesn't disrupt any existing Grid/Flexbox code in your custom.css */
  .hiw-content {
    display: contents; 
  }
}
</style>