{%- style -%}
  .rr-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .rr-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient rr-section rr-section-{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="center" style="margin-bottom: 40px;">
        <h2 class="h1">{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}

    <div class="rr-grid">
      {% for block in section.blocks %}
        <div class="rr-card" {{ block.shopify_attributes }}>
          
          <div class="rr-media-wrapper">
            {% if block.settings.video != blank %}
              {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, class: 'rr-media' }}
            {% elsif block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'rr-media' }}
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'rr-media placeholder-svg' }}
            {% endif %}

            {% if block.settings.title != blank %}
              <h3 class="rr-overlay-text">{{ block.settings.title }}</h3>
            {% endif %}
          </div>
{% if block.settings.btn_label != blank %}
  <h3>
    <a href="{{ block.settings.link }}" class="button button--secondary">{{ block.settings.btn_label }}</a>
  </h3>
{% endif %}
          
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Recommended Reading",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Section Heading",
      "default": "Recommended Reading"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Top Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Bottom Pad",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Top",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Mobile Bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Media Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Card Video",
          "info": "Overrides the image if a video is selected."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Overlay Text",
          "default": "Niche Guides"
        },
        {
          "type": "text",
          "id": "btn_label",
          "label": "Button Label",
          "default": "See Niche Guides"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Recommended Reading Grid",
      "blocks": [
        { "type": "card", "settings": { "title": "Niche Guides (Trend Research)", "btn_label": "See Niche Guides" } },
        { "type": "card", "settings": { "title": "Blogs", "btn_label": "Browse More Success Stories" } }
      ]
    }
  ]
}
{% endschema %}