{% comment %}
  Snippet: popup-form.liquid
  A custom, bulletproof popup form that bypasses Dawn's fragile modal JS.
{% endcomment %}

<custom-popup-modal {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}>
  <div id="CustomPopupForm" class="cp-modal" aria-hidden="true">
    <div class="cp-modal-content" role="dialog" aria-modal="true" tabindex="-1">
      
      <button class="cp-close-btn" data-close-popup aria-label="Close Modal" type="button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="cp-header hhss">
        <div class="cp-title  h1">{{ settings.popup_form_title | default: 'Fill Out the Form Now.' }}</div>
        {% if settings.popup_form_subtitle != blank %}
          <p class="cp-subtitle">{{ settings.popup_form_subtitle }}</p>
        {% endif %}
      </div>
      
      {% form 'contact', id: 'PopupContactForm' %}
        
        {% if form.posted_successfully? %}
          <div class="cp-success-msg">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            {{ 'templates.contact.form.post_success' | t }}
          </div>
        {% elsif form.errors %}
          <div class="cp-error-msg">
            Please check your inputs and try again.
          </div>
        {% endif %}

        <div class="cp-fields">
          <input class="cp-input" type="text" name="contact[name]" value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}" placeholder="{{ settings.popup_form_name_placeholder | default: 'Full name' }}" required>

          <input class="cp-input" type="email" name="contact[email]" value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}" placeholder="{{ settings.popup_form_email_placeholder | default: 'Email address' }}" required>

          <div class="cp-row">
            <select class="cp-input cp-select" name="contact[country]" required>
              <option value="" disabled selected>{{ settings.popup_form_country_placeholder | default: 'Country' }}</option>
              {{ all_country_option_tags }}
            </select>
            <input class="cp-input" type="text" name="contact[province]" placeholder="{{ settings.popup_form_province_placeholder | default: 'Province / State' }}" required>
          </div>

