    "shipping_structure_YnrniK": {
      "type": "shipping-structure",
      "blocks": {
        "row_hwMkVi": {
          "type": "row",
          "settings": {
            "text": "Weight-Based Pricing: Every line charges a base rate for the first weight increment, then a lower rate for each additional increment. A 100g parcel and a 150g parcel to the same destination often differ by very little, which means rounding your packaging weight down can matter more than the product weight itself. We charge on chargeable weight, the greater of actual weight and volumetric weight.",
            "icon": ""
          }
        },
        "row_tMXxTM": {
          "type": "row",
          "settings": {
            "text": "Special Cargo Surcharges: Batteries, liquids, powders, magnets, and food carry a surcharge because they require dedicated lines with restricted capacity and additional documentation. The surcharge is quoted per shipment upfront, never applied after dispatch.",
            "icon": ""
          }
        },
        "row_WEapYT": {
          "type": "row",
          "settings": {
            "text": "Peak Season Surcharge Forecast: Carriers apply peak surcharges around Chinese New Year, Q4 holiday season, and major sales events. We forecast these ahead of each peak and tell you before you commit to stock, so you can either pre-ship or price for it rather than discovering the change on an invoice.",
            "icon": ""
          }
        }
      },
      "block_order": [
        "row_hwMkVi",
        "row_tMXxTM",
        "row_WEapYT"
      ],
